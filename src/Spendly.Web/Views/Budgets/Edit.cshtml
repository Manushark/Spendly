@model Spendly.Web.Contracts.Budgets.UpdateBudgetDto

@{
    ViewData["Title"] = "Edit Budget";
    var budgetId = ViewBag.BudgetId as int? ?? 0;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-pencil-square me-2"></i>Edit Budget
                    </h4>
                </div>
                <div class="card-body p-4">
                    @if (TempData["Error"] is string errorMsg)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMsg
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Edit" asp-route-id="@budgetId" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-tag me-1"></i>Category
                            </label>
                            <input asp-for="Category" 
                                   class="form-control form-control-lg" 
                                   placeholder="e.g. Food, Transport"
                                   required 
                                   maxlength="100"
                                   list="categoryList" />
                           <datalist id="categoryList">
                                <option value="Food"></option>
                                <option value="Transport"></option>
                                <option value="Entertainment"></option>
                                <option value="Shopping"></option>
                                <option value="Utilities"></option>
                                <option value="Healthcare"></option>
                                <option value="Education"></option>
                                <option value="Other"></option>
                            </datalist>
                            <small class="text-muted">
                                You can change the category name
                            </small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-cash-stack me-1"></i>Monthly Limit
                            </label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text">$</span>
                                <input asp-for="MonthlyLimit" 
                                       type="number" 
                                       step="0.01" 
                                       min="0.01"
                                       class="form-control" 
                                       placeholder="0.00"
                                       required />
                            </div>
                            <small class="text-muted">
                                Update your spending limit for this category
                            </small>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">
                                    <i class="bi bi-calendar-event me-1"></i>Year
                                </label>
                                <input asp-for="Year" 
                                       type="number" 
                                       min="2000" 
                                       max="2100"
                                       class="form-control form-control-lg" 
                                       required />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">
                                    <i class="bi bi-calendar3 me-1"></i>Month
                                </label>
                                <select asp-for="Month" class="form-select form-select-lg" required>
                                    <option value="1">January</option>
                                    <option value="2">February</option>
                                    <option value="3">March</option>
                                    <option value="4">April</option>
                                    <option value="5">May</option>
                                    <option value="6">June</option>
                                    <option value="7">July</option>
                                    <option value="8">August</option>
                                    <option value="9">September</option>
                                    <option value="10">October</option>
                                    <option value="11">November</option>
                                    <option value="12">December</option>
                                </select>
                            </div>
                        </div>

                        <div class="alert alert-warning border-0 bg-warning bg-opacity-10">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            <strong>Note:</strong> Changing the month or year will move this budget to a different period.
                        </div>

                        <div class="d-flex gap-2 justify-content-end mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-x-circle me-1"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-circle me-1"></i>Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @* Delete Option *@
            <div class="card border-danger mt-3">
                <div class="card-body">
                    <h6 class="text-danger fw-semibold mb-2">
                        <i class="bi bi-trash me-2"></i>Danger Zone
                    </h6>
                    <p class="small text-muted mb-3">
                        Once you delete a budget, there is no going back. 
                        This action cannot be undone.
                    </p>
                    <form asp-action="Delete" asp-route-id="@budgetId" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" 
                                class="btn btn-outline-danger"
                                onclick="return confirm('Are you sure you want to delete this budget? This action cannot be undone.');">
                            <i class="bi bi-trash me-1"></i>Delete Budget
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
