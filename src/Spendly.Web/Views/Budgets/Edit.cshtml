@model Spendly.Web.Contracts.Budgets.UpdateBudgetDto
@using Spendly.Web.Services

@{
    ViewData["Title"] = L["Bud_EditBudget"].Value;
    var budgetId = ViewBag.BudgetId as int? ?? 0;
    var categories = ViewBag.Categories as List<CategoryViewModel> ?? new List<CategoryViewModel>();
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-pencil-square me-2"></i>@L["Bud_EditBudget"]
                    </h4>
                </div>
                <div class="card-body p-4">
                    @if (TempData["Error"] is string errorMsg)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMsg
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Edit" asp-route-id="@budgetId" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-tag me-1"></i>@L["Common_Category"]
                            </label>
                            @if (categories.Any())
                            {
                                <select asp-for="Category" class="form-select form-select-lg" required>
                                    <option value="" disabled>@L["Exp_SelectCategory"]</option>
                                    @foreach (var cat in categories)
                                    {
                                        <option value="@cat.Name" selected="@(Model.Category == cat.Name)">@cat.Name</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input asp-for="Category" 
                                       class="form-control form-control-lg" 
                                       placeholder="e.g. Food, Transport"
                                       required 
                                       maxlength="100" />
                            }
                            <small class="text-muted">
                                @L["Bud_ChangeCategoryNote"]
                            </small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-cash-stack me-1"></i>@L["Bud_MonthlyLimit"]
                            </label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text">$</span>
                                <input asp-for="MonthlyLimit" 
                                       type="number" 
                                       step="0.01" 
                                       min="0.01"
                                       class="form-control" 
                                       placeholder="0.00"
                                       required />
                            </div>
                            <small class="text-muted">
                                @L["Bud_UpdateLimitHint"]
                            </small>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">
                                    <i class="bi bi-calendar-event me-1"></i>@L["Common_Year"]
                                </label>
                                <input asp-for="Year" 
                                       type="number" 
                                       min="2000" 
                                       max="2100"
                                       class="form-control form-control-lg" 
                                       required />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">
                                    <i class="bi bi-calendar3 me-1"></i>@L["Common_Month"]
                                </label>
                                <select asp-for="Month" class="form-select form-select-lg" required>
                                    <option value="1">@L["Month_Jan"]</option>
                                    <option value="2">@L["Month_Feb"]</option>
                                    <option value="3">@L["Month_Mar"]</option>
                                    <option value="4">@L["Month_Apr"]</option>
                                    <option value="5">@L["Month_May"]</option>
                                    <option value="6">@L["Month_Jun"]</option>
                                    <option value="7">@L["Month_Jul"]</option>
                                    <option value="8">@L["Month_Aug"]</option>
                                    <option value="9">@L["Month_Sep"]</option>
                                    <option value="10">@L["Month_Oct"]</option>
                                    <option value="11">@L["Month_Nov"]</option>
                                    <option value="12">@L["Month_Dec"]</option>
                                </select>
                            </div>
                        </div>

                        <div class="alert alert-warning border-0 bg-warning bg-opacity-10">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            <strong>@L["Bud_NoteLabel"]:</strong> @L["Bud_MoveWarning"]
                        </div>

                        <div class="d-flex gap-2 justify-content-end mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-x-circle me-1"></i>@L["Common_Cancel"]
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-circle me-1"></i>@L["Common_Save"]
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @* Delete Option *@
            <div class="card border-danger mt-3">
                <div class="card-body">
                    <h6 class="text-danger fw-semibold mb-2">
                        <i class="bi bi-trash me-2"></i>@L["Bud_DangerZone"]
                    </h6>
                    <p class="small text-muted mb-3">
                        @L["Bud_DeleteWarning"]
                    </p>
                    <form asp-action="Delete" asp-route-id="@budgetId" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" 
                                class="btn btn-outline-danger"
                                onclick="return confirm('@L["Bud_DeleteConfirm"].Value');">
                            <i class="bi bi-trash me-1"></i>@L["Bud_DeleteBudget"]
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
