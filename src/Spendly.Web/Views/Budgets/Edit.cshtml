@model Spendly.Web.Contracts.Budgets.UpdateBudgetDto
@using Spendly.Web.Services

@{
    ViewData["Title"] = L["Bud_EditBudget"].Value;
    var budgetId = ViewBag.BudgetId as int? ?? 0;
    var categories = ViewBag.Categories as List<CategoryViewModel> ?? new List<CategoryViewModel>();
}

<style>
    .form-card-premium {
        border-radius: 16px;
        border: 1px solid var(--clr-border);
        background: var(--clr-bg-card);
        box-shadow: var(--shadow-md);
        overflow: hidden;
    }
    .form-label-custom {
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--clr-text-muted);
        font-weight: 600;
    }
    .danger-zone-card {
        border-radius: 12px;
        border: 1px solid rgba(220, 38, 38, 0.2);
        background: rgba(220, 38, 38, 0.03);
    }
</style>

<div class="container mt-4" style="max-width: 650px;">
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="form-card-premium">
                <div class="card-header bg-primary text-white py-3 px-4 border-0">
                    <h4 class="mb-0 fw-bold" style="font-family:'Calistoga',serif;">
                        <i class="bi bi-pencil-square me-2"></i>@L["Bud_EditBudget"]
                    </h4>
                </div>
                <div class="card-body p-4">
                    @if (TempData["Error"] is string errorMsg)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius:10px;">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMsg
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Edit" asp-route-id="@budgetId" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-4">
                            <label class="form-label form-label-custom mb-2">
                                <i class="bi bi-tag me-1"></i>@L["Common_Category"]
                            </label>
                            @if (categories.Any())
                            {
                                <select asp-for="Category" class="form-select form-select-lg rounded-3" style="font-size:1rem; padding:12px 15px;" required>
                                    <option value="" disabled>@L["Exp_SelectCategory"]</option>
                                    @foreach (var cat in categories)
                                    {
                                        <option value="@cat.Name" selected="@(Model.Category == cat.Name)">@CategoryTranslator.Translate(cat.Name, L)</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input asp-for="Category" 
                                       class="form-control form-control-lg rounded-3" 
                                       placeholder="e.g. Food, Transport"
                                       required 
                                       maxlength="100" />
                            }
                            <small class="text-muted d-block mt-1">
                                @L["Bud_ChangeCategoryNote"]
                            </small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label form-label-custom mb-2">
                                <i class="bi bi-cash-stack me-1"></i>@L["Bud_MonthlyLimit"]
                            </label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text rounded-start-3" style="background: var(--clr-surface-3); border-color: var(--clr-border);">$</span>
                                <input asp-for="MonthlyLimit" 
                                       type="number" 
                                       step="0.01" 
                                       min="0.01"
                                       class="form-control rounded-end-3 font-mono fw-bold" 
                                       placeholder="@L["Ph_Zero"]"
                                       required />
                            </div>
                            <small class="text-muted d-block mt-1">
                                @L["Bud_UpdateLimitHint"]
                            </small>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label class="form-label form-label-custom mb-2">
                                    <i class="bi bi-calendar-event me-1"></i>@L["Common_Year"]
                                </label>
                                <input asp-for="Year" 
                                       type="number" 
                                       min="2000" 
                                       max="2100"
                                       class="form-control form-control-lg rounded-3 font-mono" 
                                       required />
                            </div>

                            <div class="col-md-6 mb-4">
                                <label class="form-label form-label-custom mb-2">
                                    <i class="bi bi-calendar3 me-1"></i>@L["Common_Month"]
                                </label>
                                <select asp-for="Month" class="form-select form-select-lg rounded-3" style="font-size:1rem; padding:12px 15px;" required>
                                    <option value="1">@L["Month_Jan"]</option>
                                    <option value="2">@L["Month_Feb"]</option>
                                    <option value="3">@L["Month_Mar"]</option>
                                    <option value="4">@L["Month_Apr"]</option>
                                    <option value="5">@L["Month_May"]</option>
                                    <option value="6">@L["Month_Jun"]</option>
                                    <option value="7">@L["Month_Jul"]</option>
                                    <option value="8">@L["Month_Aug"]</option>
                                    <option value="9">@L["Month_Sep"]</option>
                                    <option value="10">@L["Month_Oct"]</option>
                                    <option value="11">@L["Month_Nov"]</option>
                                    <option value="12">@L["Month_Dec"]</option>
                                </select>
                            </div>
                        </div>

                        <div class="alert alert-warning border-0 bg-warning bg-opacity-10 mb-4" style="border-radius:10px;">
                            <i class="bi bi-exclamation-triangle-fill me-2 text-warning"></i>
                            <strong>@L["Bud_NoteLabel"]:</strong> @L["Bud_MoveWarning"]
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                                <i class="bi bi-x-circle me-1"></i>@L["Common_Cancel"]
                            </a>
                            <button type="submit" class="btn btn-primary rounded-pill px-4">
                                <i class="bi bi-check-circle me-1"></i>@L["Common_Save"]
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @* Delete Option (Danger Zone) *@
            <div class="danger-zone-card mt-3">
                <div class="card-body p-4">
                    <h6 class="text-danger fw-bold mb-2" style="font-family:'Calistoga',serif;">
                        <i class="bi bi-trash-fill me-2"></i>@L["Bud_DangerZone"]
                    </h6>
                    <p class="small text-muted mb-3">
                        @L["Bud_DeleteWarning"]
                    </p>
                    <form asp-action="Delete" asp-route-id="@budgetId" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" 
                                class="btn btn-outline-danger rounded-pill px-4"
                                onclick="return confirm('@L["Bud_DeleteConfirm"].Value');">
                            <i class="bi bi-trash me-1"></i>@L["Bud_DeleteBudget"]
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
