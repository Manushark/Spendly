@model Spendly.Web.Contracts.Budgets.BudgetSummaryDto

@{
    ViewData["Title"] = L["Bud_Title"].Value;
    var monthName = ViewBag.MonthName as string ?? DateTime.Now.ToString("MMMM yyyy");
}

<style>
    /* KPI card design */
    .kpi-card {
        border-radius: 16px;
        border: 1px solid var(--clr-border);
        background: var(--clr-bg-card);
        box-shadow: var(--shadow-sm);
        transition: transform 0.25s var(--ease-out), box-shadow 0.25s var(--ease-out);
        overflow: hidden;
        position: relative;
    }
    .kpi-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-md);
    }
    .kpi-card .kpi-accent {
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        border-radius: 16px 16px 0 0;
    }
    .kpi-accent-green  { background: linear-gradient(90deg, #10b981, #34d399); }
    .kpi-accent-red    { background: linear-gradient(90deg, #ef4444, #f87171); }
    .kpi-accent-blue   { background: linear-gradient(90deg, #3b82f6, #60a5fa); }
    .kpi-accent-violet { background: linear-gradient(90deg, #8b5cf6, #a78bfa); }

    .kpi-icon {
        width: 44px; height: 44px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.25rem;
        flex-shrink: 0;
    }
    .kpi-icon-green  { background: rgba(16,185,129,.14); color: #10b981; }
    .kpi-icon-red    { background: rgba(239,68,68,.14);  color: #ef4444; }
    .kpi-icon-blue   { background: rgba(59,130,246,.14); color: #3b82f6; }
    .kpi-icon-violet { background: rgba(139,92,246,.14); color: #8b5cf6; }

    /* Budget Card Style */
    .budget-card-premium {
        border-radius: 16px;
        border: 1px solid var(--clr-border);
        background: var(--clr-bg-card);
        box-shadow: var(--shadow-sm);
        transition: transform 0.25s var(--ease-out), box-shadow 0.25s var(--ease-out);
        overflow: hidden;
    }
    .budget-card-premium:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-md);
    }
    
    .progress-bar-safe {
        background: linear-gradient(90deg, #10b981, #34d399);
    }
    .progress-bar-warning {
        background: linear-gradient(90deg, #f59e0b, #fbbf24);
    }
    .progress-bar-critical {
        background: linear-gradient(90deg, #ef4444, #f87171);
    }
</style>

<div class="container-fluid py-4">
    @* Header *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1" style="font-family:'Calistoga',serif; letter-spacing:-0.5px;">
                <i class="bi bi-piggy-bank text-primary me-2"></i>@L["Bud_Title"]
            </h2>
            <small class="text-muted">
                <i class="bi bi-calendar3"></i> @monthName
            </small>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 fw-semibold">
            <i class="bi bi-plus-circle me-1"></i> @L["Bud_NewBudget"]
        </a>
    </div>

    @* Alerts *@
    @if (TempData["Error"] is string errorMsg)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: 12px;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Success"] is string successMsg)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: 12px;">
            <i class="bi bi-check-circle-fill me-2"></i>@successMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Budgets.Any())
    {
        @* Empty State *@
        <div class="card budget-card-premium border-0">
            <div class="card-body text-center py-5">
                <div class="mb-4 text-muted" style="font-size: 80px; opacity: 0.3;">
                    <i class="bi bi-piggy-bank"></i>
                </div>
                <h3 class="mb-3" style="font-family:'Calistoga',serif;">@L["Bud_NoBudgets"]</h3>
                <p class="text-muted mb-4">@L["Bud_CreateFirst"]</p>
                <a asp-action="Create" class="btn btn-primary btn-lg rounded-pill px-5">
                    <i class="bi bi-plus-circle me-2"></i>@L["Bud_NewBudget"]
                </a>
            </div>
        </div>
    }
    else
    {
        @* Summary Cards *@
        <div class="row g-3 mb-4">
            <!-- KPI: Total Budget -->
            <div class="col-sm-6 col-xl-3">
                <div class="kpi-card h-100 p-4">
                    <div class="kpi-accent kpi-accent-blue"></div>
                    <div class="d-flex justify-content-between align-items-center mb-3 pt-1">
                        <span class="text-muted fw-semibold small text-uppercase" style="letter-spacing:.5px;">@L["Bud_TotalBudget"]</span>
                        <div class="kpi-icon kpi-icon-blue"><i class="bi bi-cash-stack"></i></div>
                    </div>
                    <h2 class="fw-bold font-mono mb-1 text-primary" style="font-size:1.8rem;">
                        $@Model.TotalLimit.ToString("N2")
                    </h2>
                    <small class="text-muted">@Model.TotalBudgets @L["Bud_BudgetsSet"]</small>
                </div>
            </div>

            <!-- KPI: Total Spent -->
            <div class="col-sm-6 col-xl-3">
                <div class="kpi-card h-100 p-4">
                    <div class="kpi-accent kpi-accent-violet"></div>
                    <div class="d-flex justify-content-between align-items-center mb-3 pt-1">
                        <span class="text-muted fw-semibold small text-uppercase" style="letter-spacing:.5px;">@L["Bud_TotalSpent"]</span>
                        <div class="kpi-icon kpi-icon-violet"><i class="bi bi-receipt"></i></div>
                    </div>
                    <h2 class="fw-bold font-mono mb-1 text-danger" style="font-size:1.8rem;">
                        $@Model.TotalSpent.ToString("N2")
                    </h2>
                    @{
                        var totalPercentage = Model.TotalLimit > 0 ? (Model.TotalSpent / Model.TotalLimit) * 100 : 0;
                    }
                    <small class="text-muted">@totalPercentage.ToString("N0")% @L["Bud_OfTotalBudget"]</small>
                </div>
            </div>

            <!-- KPI: Remaining -->
            <div class="col-sm-6 col-xl-3">
                <div class="kpi-card h-100 p-4">
                    <div class="kpi-accent kpi-accent-green"></div>
                    <div class="d-flex justify-content-between align-items-center mb-3 pt-1">
                        <span class="text-muted fw-semibold small text-uppercase" style="letter-spacing:.5px;">@L["Bud_Remaining"]</span>
                        <div class="kpi-icon kpi-icon-green"><i class="bi bi-wallet2"></i></div>
                    </div>
                    <h2 class="fw-bold font-mono mb-1 text-success" style="font-size:1.8rem;">
                        $@Model.TotalRemaining.ToString("N2")
                    </h2>
                    <small class="text-muted">@L["Bud_AvailableToSpend"]</small>
                </div>
            </div>

            <!-- KPI: Over Budget -->
            <div class="col-sm-6 col-xl-3">
                <div class="kpi-card h-100 p-4">
                    <div class="kpi-accent kpi-accent-red"></div>
                    <div class="d-flex justify-content-between align-items-center mb-3 pt-1">
                        <span class="text-muted fw-semibold small text-uppercase" style="letter-spacing:.5px;">@L["Bud_OverBudget"]</span>
                        <div class="kpi-icon kpi-icon-red"><i class="bi bi-exclamation-triangle"></i></div>
                    </div>
                    <h2 class="fw-bold font-mono mb-1 @(Model.BudgetsExceeded > 0 ? "text-danger" : "text-muted")" style="font-size:1.8rem;">
                        @Model.BudgetsExceeded
                    </h2>
                    <small class="text-muted">@L["Bud_CategoriesExceeded"]</small>
                </div>
            </div>
        </div>

        @* Budget List *@
        <div class="row g-4">
            @foreach (var budget in Model.Budgets)
            {
                var progressClass = budget.PercentageUsed >= 100 ? "progress-bar-critical" :
                                   budget.PercentageUsed >= 80 ? "progress-bar-warning" : "progress-bar-safe";

                var badgeClass = budget.PercentageUsed >= 100 ? "bg-danger" :
                                budget.PercentageUsed >= 80 ? "bg-warning text-dark" : "bg-success";

                <div class="col-md-6 col-xl-4">
                    <div class="card budget-card-premium h-100">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="flex-grow-1">
                                    <h5 class="mb-1 fw-bold text-truncate" style="font-family:'Calistoga',serif;">
                                        <i class="bi bi-tag-fill me-2 text-primary"></i>@CategoryTranslator.Translate(budget.Category, L)
                                    </h5>
                                    <small class="text-muted font-mono">
                                        @budget.Month/@budget.Year
                                    </small>
                                </div>
                                <div class="d-flex gap-1">
                                    <a asp-action="Edit" asp-route-id="@budget.Id" 
                                       class="btn btn-sm btn-outline-primary rounded-circle" 
                                       style="width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center;"
                                       title="@L["Common_Edit"]">
                                        <i class="bi bi-pencil" style="font-size: 0.85rem;"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@budget.Id" 
                                          method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle"
                                                style="width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center;"
                                                title="@L["Common_Delete"]"
                                                onclick="return confirm('@L["Bud_DeleteConfirm"].Value');">
                                            <i class="bi bi-trash" style="font-size: 0.85rem;"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>

                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="small text-muted fw-semibold">
                                        @L["Common_Spent"]: <span class="text-danger font-mono fw-bold">$@budget.Spent.ToString("N2")</span>
                                    </span>
                                    <span class="small text-muted fw-semibold">
                                        @L["Bud_Limit"]: <span class="text-success font-mono fw-bold">$@budget.MonthlyLimit.ToString("N2")</span>
                                    </span>
                                </div>
                                <div class="progress" style="height: 8px; border-radius: 10px; background: var(--clr-surface-3);">
                                    <div class="progress-bar @progressClass" 
                                         role="progressbar"
                                         style="width: @Math.Min(budget.PercentageUsed, 100).ToString(System.Globalization.CultureInfo.InvariantCulture)%"
                                         aria-valuenow="@budget.PercentageUsed"
                                         aria-valuemin="0"
                                         aria-valuemax="100"></div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                <span class="badge @badgeClass rounded-pill px-3 py-2 fw-semibold" style="font-size: 0.75rem;">
                                    @budget.PercentageUsed.ToString("N0")% @L["Bud_Used"]
                                </span>
                                @if (budget.Remaining >= 0)
                                {
                                    <span class="text-success small fw-semibold font-mono">
                                        <i class="bi bi-check-circle me-1"></i>
                                        $@budget.Remaining.ToString("N2") @L["Dash_Remaining"]
                                    </span>
                                }
                                else
                                {
                                    <span class="text-danger small fw-semibold font-mono">
                                        <i class="bi bi-exclamation-triangle me-1"></i>
                                        $@Math.Abs(budget.Remaining).ToString("N2") @L["Bud_OverBudgetAmount"]
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
