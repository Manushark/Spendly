@model Spendly.Web.Contracts.Budgets.CreateBudgetDto

@{
    ViewData["Title"] = "Create Budget";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-plus-circle me-2"></i>Create New Budget
                    </h4>
                </div>
                <div class="card-body p-4">
                    @if (TempData["Error"] is string errorMsg)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMsg
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-tag me-1"></i>Category
                            </label>
                            <input asp-for="Category" 
                                   class="form-control form-control-lg" 
                                   placeholder="e.g. Food, Transport, Entertainment"
                                   required 
                                   maxlength="100"
                                   list="categoryList" />
                            <datalist id="categoryList">
                                <option value="Food"></option>
                                <option value="Transport"></option>
                                <option value="Entertainment"></option>
                                <option value="Shopping"></option>
                                <option value="Utilities"></option>
                                <option value="Healthcare"></option>
                                <option value="Education"></option>
                                <option value="Other"></option>
                            </datalist>
                            <small class="text-muted">
                                Choose an existing category or create a new one
                            </small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-cash-stack me-1"></i>Monthly Limit
                            </label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text">$</span>
                                <input asp-for="MonthlyLimit" 
                                       type="number" 
                                       step="0.01" 
                                       min="0.01"
                                       class="form-control" 
                                       placeholder="0.00"
                                       required />
                            </div>
                            <small class="text-muted">
                                Maximum amount you want to spend in this category per month
                            </small>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">
                                    <i class="bi bi-calendar-event me-1"></i>Year
                                </label>
                                <input asp-for="Year" 
                                       type="number" 
                                       min="2000" 
                                       max="2100"
                                       class="form-control form-control-lg" 
                                       required />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">
                                    <i class="bi bi-calendar3 me-1"></i>Month
                                </label>
                                <select asp-for="Month" class="form-select form-select-lg" required>
                                    <option value="1">January</option>
                                    <option value="2">February</option>
                                    <option value="3">March</option>
                                    <option value="4">April</option>
                                    <option value="5">May</option>
                                    <option value="6">June</option>
                                    <option value="7">July</option>
                                    <option value="8">August</option>
                                    <option value="9">September</option>
                                    <option value="10">October</option>
                                    <option value="11">November</option>
                                    <option value="12">December</option>
                                </select>
                            </div>
                        </div>

                        <div class="alert alert-info border-0 bg-info bg-opacity-10">
                            <i class="bi bi-info-circle me-2"></i>
                            <strong>Tip:</strong> You can only have one budget per category per month. 
                            If you already have a budget for this category and month, you'll need to edit it instead.
                        </div>

                        <div class="d-flex gap-2 justify-content-end mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-x-circle me-1"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-circle me-1"></i>Create Budget
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @* Quick Tips *@
            <div class="card border-0 bg-light mt-3">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3">
                        <i class="bi bi-lightbulb text-warning me-2"></i>Budget Tips
                    </h6>
                    <ul class="mb-0 small">
                        <li class="mb-2">Start with your most important spending categories</li>
                        <li class="mb-2">Review your past expenses to set realistic limits</li>
                        <li class="mb-2">Adjust budgets monthly as your needs change</li>
                        <li>Leave some buffer for unexpected expenses</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Set current year and month as defaults if not set
        document.addEventListener('DOMContentLoaded', function() {
            const monthSelect = document.querySelector('select[name="Month"]');
            const yearInput = document.querySelector('input[name="Year"]');
            
            if (monthSelect && monthSelect.value) {
                monthSelect.value = '@Model.Month';
            }
            if (yearInput && yearInput.value) {
                yearInput.value = '@Model.Year';
            }
        });
    </script>
}