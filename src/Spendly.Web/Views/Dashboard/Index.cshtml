@model Spendly.Web.Contracts.Dashboard.DashboardStatsDto

@{
    ViewData["Title"] = L["Dash_Title"].Value;
    var hasData = Model.TotalExpensesCount > 0;
}

<style>
    /* ── KPI CARDS ──────────────────────────────────────────── */
    .kpi-card {
        border-radius: 16px;
        border: 1px solid var(--clr-border);
        background: var(--clr-surface);
        box-shadow: var(--shadow-sm);
        transition: transform 0.25s var(--ease-out), box-shadow 0.25s var(--ease-out);
        overflow: hidden;
        position: relative;
    }
    .kpi-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-md);
    }
    /* Coloured top border accent */
    .kpi-card .kpi-accent {
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        border-radius: 16px 16px 0 0;
    }
    .kpi-accent-green  { background: linear-gradient(90deg, #10b981, #34d399); }
    .kpi-accent-red    { background: linear-gradient(90deg, #ef4444, #f87171); }
    .kpi-accent-blue   { background: linear-gradient(90deg, #3b82f6, #60a5fa); }
    .kpi-accent-violet { background: linear-gradient(90deg, #8b5cf6, #a78bfa); }

    .kpi-icon {
        width: 44px; height: 44px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.25rem;
        flex-shrink: 0;
    }
    .kpi-icon-green  { background: rgba(16,185,129,.14); color: #10b981; }
    .kpi-icon-red    { background: rgba(239,68,68,.14);  color: #ef4444; }
    .kpi-icon-blue   { background: rgba(59,130,246,.14); color: #3b82f6; }
    .kpi-icon-violet { background: rgba(139,92,246,.14); color: #8b5cf6; }

    /* ── GLASS PANEL (chart/table cards) ────────────────────── */
    .glass-card {
        border-radius: 16px;
        border: 1px solid var(--clr-border);
        background: var(--clr-surface);
        box-shadow: var(--shadow-sm);
        transition: transform 0.25s var(--ease-out), box-shadow 0.25s var(--ease-out);
        overflow: hidden;
    }
    .glass-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-md);
    }

    /* ── PROGRESS TRACK ─────────────────────────────────────── */
    .progress-track-premium {
        height: 6px;
        background: var(--clr-surface-3);
        border-radius: 10px; overflow: hidden;
    }
    .progress-bar-premium {
        height: 100%; border-radius: 10px;
        transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* ── CATEGORY ROW HOVER ─────────────────────────────────── */
    .category-row-premium {
        transition: background 0.15s ease, transform 0.15s ease;
        border-radius: 10px;
    }
    .category-row-premium:hover {
        background: var(--clr-surface-3) !important;
        transform: translateX(4px);
    }

    /* ── LAST-30-DAYS BADGE ─────────────────────────────────── */
    .badge-label {
        font-size: 0.7rem;
        font-weight: 600;
        padding: 2px 10px;
        border-radius: 20px;
        background: var(--clr-secondary);
        color: #fff;
        letter-spacing: 0.3px;
        opacity: 0.85;
    }

    /* ── EMPTY STATE ────────────────────────────────────────── */
    .empty-state { padding: 80px 20px; text-align: center; }

    /* ── DARK-MODE OVERRIDES FOR TABLE ─────────────────────── */
    /* Ensure count badge always has readable text */
    .count-badge {
        background: var(--clr-surface-3) !important;
        color: var(--clr-text) !important;
        border: 1px solid var(--clr-border);
        font-family: var(--font-mono);
        font-size: 0.78rem;
        padding: 3px 10px;
        border-radius: 20px;
        display: inline-block;
    }
    /* Amount text in table always vivid */
    .amount-cell {
        font-family: var(--font-mono);
        font-weight: 700;
        color: var(--clr-text) !important;
    }
</style>

<div class="container-fluid py-4">

    @* ─── Header ─────────────────────────────────────────────── *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1" style="font-family:'Calistoga',serif;letter-spacing:-0.5px;">
                <i class="bi bi-speedometer2 text-primary me-2"></i>@L["Dash_Title"]
                <button class="help-trigger" data-help-trigger data-help-title="@L["Help_Dash_Title"]" data-help-body="@L["Help_Dash_Body"]" data-help-icon="bi-speedometer2" title="Ayuda / Help">?</button>
            </h2>
            <small class="text-muted">
                <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("MMMM yyyy")
            </small>
        </div>
        @if (hasData)
        {
            <a asp-controller="Expenses" asp-action="Index" class="btn btn-primary rounded-pill px-4 fw-semibold">
                <i class="bi bi-plus-circle me-2"></i>@L["Dash_AddExpense"]
            </a>
        }
    </div>

    @if (!hasData)
    {
        <div class="row">
            <div class="col-12">
                <div class="kpi-card p-5 text-center">
                    <i class="bi bi-wallet2 text-primary" style="font-size:5rem;opacity:.4;"></i>
                    <h3 class="mt-3" style="font-family:'Calistoga',serif;">@L["Dash_NoExpensesMonth"]</h3>
                    <p class="text-muted mb-4">@L["Dash_StartTracking"]</p>
                    <a asp-controller="Expenses" asp-action="Index" class="btn btn-primary rounded-pill px-4 py-2 fw-semibold">
                        <i class="bi bi-plus-circle me-2"></i>@L["Dash_AddFirstExpense"]
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        @* ─── KPI Cards ──────────────────────────────────────────── *@
        <div class="row g-3 mb-4">

            @* Card: Income *@
            <div class="col-sm-6 col-xl-3">
                <div class="kpi-card h-100 p-4">
                    <div class="kpi-accent kpi-accent-green"></div>
                    <div class="d-flex justify-content-between align-items-center mb-3 pt-1">
                        <span class="text-muted fw-semibold small text-uppercase" style="letter-spacing:.5px;">@L["Dash_MonthlyIncome"]</span>
                        <div class="kpi-icon kpi-icon-green"><i class="bi bi-cash-stack"></i></div>
                    </div>
                    <h2 class="fw-bold font-mono mb-1" style="color:#10b981;font-size:1.8rem;">
                        $@Model.CurrentMonthIncome.ToString("N2")
                    </h2>
                    <small class="text-muted">@L["Dash_TotalEarnings"]</small>
                </div>
            </div>

            @* Card: Expenses *@
            <div class="col-sm-6 col-xl-3">
                <div class="kpi-card h-100 p-4">
                    <div class="kpi-accent kpi-accent-red"></div>
                    <div class="d-flex justify-content-between align-items-center mb-3 pt-1">
                        <span class="text-muted fw-semibold small text-uppercase" style="letter-spacing:.5px;">@L["Dash_TotalThisMonth"]</span>
                        <div class="kpi-icon kpi-icon-red"><i class="bi bi-wallet2"></i></div>
                    </div>
                    <h2 class="fw-bold font-mono mb-1" style="color:#ef4444;font-size:1.8rem;">
                        $@Model.CurrentMonthTotal.ToString("N2")
                    </h2>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        @if (Model.PreviousMonthTotal > 0)
                        {
                            <span class="trend-indicator @(Model.IsIncreaseFromLastMonth ? "trend-up" : "trend-down")">
                                <i class="bi bi-arrow-@(Model.IsIncreaseFromLastMonth ? "up" : "down") me-1"></i>
                                @Math.Abs(Model.MonthComparisonPercentage).ToString("N1")%
                            </span>
                            <small class="text-muted">@L["Dash_VsLastMonth"]</small>
                        }
                        else
                        {
                            <small class="text-muted">@L["Dash_TotalEarnings"]</small>
                        }
                    </div>
                </div>
            </div>

            @* Card: Balance *@
            <div class="col-sm-6 col-xl-3">
                <div class="kpi-card h-100 p-4">
                    <div class="kpi-accent @(Model.MonthlyBalance >= 0 ? "kpi-accent-blue" : "kpi-accent-red")"></div>
                    <div class="d-flex justify-content-between align-items-center mb-3 pt-1">
                        <span class="text-muted fw-semibold small text-uppercase" style="letter-spacing:.5px;">@L["Dash_Balance"]</span>
                        <div class="kpi-icon @(Model.MonthlyBalance >= 0 ? "kpi-icon-blue" : "kpi-icon-red")">
                            <i class="bi bi-wallet-fill"></i>
                        </div>
                    </div>
                    <h2 class="fw-bold font-mono mb-1" style="color:@(Model.MonthlyBalance >= 0 ? "#3b82f6" : "#ef4444");font-size:1.8rem;">
                        @(Model.MonthlyBalance >= 0 ? "+" : "")$@Math.Abs(Model.MonthlyBalance).ToString("N2")
                    </h2>
                    <small class="text-muted">@L["Dash_IncomeMinusExpenses"]</small>
                </div>
            </div>

            @* Card: Savings Rate *@
            <div class="col-sm-6 col-xl-3">
                <div class="kpi-card h-100 p-4">
                    <div class="kpi-accent kpi-accent-violet"></div>
                    <div class="d-flex justify-content-between align-items-center mb-3 pt-1">
                        <span class="text-muted fw-semibold small text-uppercase" style="letter-spacing:.5px;">@L["Dash_SavingsRate"]</span>
                        <div class="kpi-icon kpi-icon-violet"><i class="bi bi-piggy-bank"></i></div>
                    </div>
                    <h2 class="fw-bold font-mono mb-2" style="color:#8b5cf6;font-size:1.8rem;">
                        @Model.SavingsRate.ToString("N1")%
                    </h2>
                    <div class="progress-track-premium mb-2">
                        <div class="progress-bar-premium"
                             style="width:@(Math.Max(0,Math.Min(100,Model.SavingsRate)).ToString(System.Globalization.CultureInfo.InvariantCulture))%;
                                    background:@(Model.SavingsRate >= 20 ? "linear-gradient(90deg,#10b981,#34d399)" : Model.SavingsRate >= 0 ? "linear-gradient(90deg,#f59e0b,#fbbf24)" : "linear-gradient(90deg,#ef4444,#f87171)");">
                        </div>
                    </div>
                    <div class="d-flex justify-content-between">
                        <small class="text-muted text-truncate" style="max-width:110px;" title="@Model.TopCategory">
                            <i class="bi bi-tag me-1"></i>@Model.TopCategory
                        </small>
                        <small class="text-muted font-mono">@Model.TotalExpensesCount txs</small>
                    </div>
                </div>
            </div>

        </div>

        @* ─── Row 2: Trend Chart + Top 5 ─────────────────────────── *@
        <div class="row g-3 mb-4">
            <div class="col-lg-8">
                <div class="glass-card h-100">
                    <div class="card-header border-0 bg-transparent pt-4 pb-2 px-4 d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-bar-chart-line text-primary"></i>
                            <h5 class="mb-0 fw-semibold">Income vs Expenses</h5>
                        </div>
                        <div class="d-flex align-items-center gap-3" style="font-size:.78rem;">
                            <span class="d-flex align-items-center gap-1"><span style="width:10px;height:10px;border-radius:3px;background:#10b981;display:inline-block;"></span><span class="text-muted">Income</span></span>
                            <span class="d-flex align-items-center gap-1"><span style="width:10px;height:10px;border-radius:3px;background:#ef4444;display:inline-block;"></span><span class="text-muted">This month</span></span>
                            <span class="d-flex align-items-center gap-1"><span style="width:10px;height:10px;border-radius:3px;background:#94a3b8;display:inline-block;"></span><span class="text-muted">Last month</span></span>
                        </div>
                    </div>
                    <div class="card-body pt-2 px-3 pb-3">
                        <div style="position:relative;height:300px;width:100%;">
                            <canvas id="dailyTrendChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="glass-card h-100">
                    <div class="card-header border-0 bg-transparent pt-4 pb-2 px-4 d-flex align-items-center gap-2">
                        <i class="bi bi-star-fill text-warning"></i>
                        <h5 class="mb-0 fw-semibold">@L["Dash_Top5Expenses"]</h5>
                    </div>
                    <div class="card-body p-0">
                        @if (Model.TopExpenses.Any())
                        {
                            <div class="d-flex flex-column px-3 pb-3 pt-1 gap-2">
                                @foreach (var exp in Model.TopExpenses)
                                {
                                    var icon = GetCategoryIcon(exp.Category);
                                    var color = GetCategoryColor(exp.Category, 0);
                                    <div class="d-flex justify-content-between align-items-center px-3 py-2 rounded-3 category-row-premium" style="border:1px solid var(--clr-border);">
                                        <div class="d-flex align-items-center gap-2 min-w-0">
                                            <span class="flex-shrink-0" style="width:34px;height:34px;border-radius:9px;background:@(color)22;color:@color;border:1px solid @(color)44;display:inline-flex;align-items:center;justify-content:center;font-size:1rem;" title="@CategoryTranslator.Translate(exp.Category, L)">
                                                <i class="bi @icon"></i>
                                            </span>
                                            <div class="min-w-0">
                                                <div class="fw-semibold text-truncate" style="font-size:.85rem;max-width:110px;">@exp.Description</div>
                                                <small class="text-muted" style="font-size:.72rem;">@exp.Date.ToString("MMM dd, yyyy")</small>
                                            </div>
                                        </div>
                                        <span class="font-mono fw-bold flex-shrink-0 ms-2" style="color:#ef4444;font-size:.88rem;">
                                            -$@exp.Amount.ToString("N2")
                                        </span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* ─── Row 3: Category Table + % Breakdown ────────────────── *@
        <div class="row g-3">
            <div class="col-lg-8">
                <div class="glass-card h-100">
                    <div class="card-header border-0 bg-transparent pt-4 pb-2 px-4 d-flex align-items-center gap-2">
                        <i class="bi bi-list-ul text-primary"></i>
                        <h5 class="mb-0 fw-semibold">@L["Dash_CategoryBreakdown"]</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle" style="background:transparent;">
                                <thead>
                                    <tr style="border-bottom:2px solid var(--clr-border);">
                                        <th class="ps-4 py-3 text-muted fw-semibold" style="font-size:.72rem;text-transform:uppercase;letter-spacing:.06em;">@L["Common_Category"]</th>
                                        <th class="py-3 text-end text-muted fw-semibold" style="font-size:.72rem;text-transform:uppercase;letter-spacing:.06em;">@L["Common_Amount"]</th>
                                        <th class="py-3 text-center text-muted fw-semibold" style="font-size:.72rem;text-transform:uppercase;letter-spacing:.06em;">@L["Dash_Count"]</th>
                                        <th class="py-3 pe-4 text-muted fw-semibold" style="font-size:.72rem;text-transform:uppercase;letter-spacing:.06em;width:220px;">@L["Dash_OfTotal"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @{
                                    int index = 0;
                                    foreach (var cat in Model.CategoryBreakdown)
                                    {
                                        var color = GetCategoryColor(cat.Category, index++);
                                        var icon  = GetCategoryIcon(cat.Category);
                                        <tr class="category-row-premium" style="border-bottom:1px solid var(--clr-border);">
                                            <td class="ps-4 py-3">
                                                <div class="d-flex align-items-center gap-2">
                                                    <span class="flex-shrink-0" style="width:30px;height:30px;border-radius:8px;background:@(color)22;color:@color;border:1px solid @(color)44;display:inline-flex;align-items:center;justify-content:center;font-size:.9rem;" title="@CategoryTranslator.Translate(cat.Category, L)">
                                                        <i class="bi @icon"></i>
                                                    </span>
                                                    <span class="fw-semibold" style="font-size:.88rem;">@CategoryTranslator.Translate(cat.Category, L)</span>
                                                </div>
                                            </td>
                                            <td class="text-end py-3">
                                                <span class="amount-cell fw-bold" style="font-size:.9rem;">$@cat.Total.ToString("N2")</span>
                                            </td>
                                            <td class="text-center py-3">
                                                <span class="count-badge">@cat.Count</span>
                                            </td>
                                            <td class="pe-4 py-3">
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="progress-track-premium flex-grow-1" style="height:7px;">
                                                        <div class="progress-bar-premium"
                                                             style="width:@cat.Percentage.ToString(System.Globalization.CultureInfo.InvariantCulture)%;background:linear-gradient(90deg,@color,@(color)bb);">
                                                        </div>
                                                    </div>
                                                    <span class="fw-bold font-mono text-muted" style="font-size:.78rem;min-width:34px;">@cat.Percentage.ToString("N0")%</span>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="glass-card h-100">
                    <div class="card-header border-0 bg-transparent pt-4 pb-2 px-4 d-flex align-items-center gap-2">
                        <i class="bi bi-pie-chart text-primary"></i>
                        <h5 class="mb-0 fw-semibold">@L["Ins_Percentage"]</h5>
                    </div>
                    <div class="card-body pt-2 px-4">
                        @if (Model.CategoryBreakdown.Any())
                        {
                            <div class="d-flex flex-column gap-3">
                                @for (int i = 0; i < Math.Min(5, Model.CategoryBreakdown.Count); i++)
                                {
                                    var cat   = Model.CategoryBreakdown[i];
                                    var color = GetCategoryColor(cat.Category, i);
                                    var icon  = GetCategoryIcon(cat.Category);
                                    <div>
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="flex-shrink-0" style="width:22px;height:22px;border-radius:6px;background:@(color)22;color:@color;border:1px solid @(color)44;display:inline-flex;align-items:center;justify-content:center;font-size:.75rem;" title="@CategoryTranslator.Translate(cat.Category, L)">
                                                    <i class="bi @icon"></i>
                                                </span>
                                                <span class="fw-semibold" style="font-size:.82rem;">@CategoryTranslator.Translate(cat.Category, L)</span>
                                            </div>
                                            <div class="text-end">
                                                <span class="amount-cell fw-bold" style="font-size:.82rem;">$@cat.Total.ToString("N2")</span>
                                                <span class="text-muted ms-1" style="font-size:.75rem;">(@cat.Percentage.ToString("N0")%)</span>
                                            </div>
                                        </div>
                                        <div class="progress-track-premium">
                                            <div class="progress-bar-premium" style="width:@cat.Percentage.ToString(System.Globalization.CultureInfo.InvariantCulture)%;background:linear-gradient(90deg,@color,@(color)bb);"></div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center text-muted py-5">
                                <i class="bi bi-inbox fs-1 d-block mb-2 opacity-40"></i>
                                @L["Common_NoData"]
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="~/lib/chart.js/chart.umd.min.js"></script>
    <script>
    @if (hasData)
    {
        <text>
        // ── Income vs Expenses grouped bar chart ──────────────────────
        const incomeVal   = @Model.CurrentMonthIncome.ToString(System.Globalization.CultureInfo.InvariantCulture);
        const expenseCurr = @Model.CurrentMonthTotal.ToString(System.Globalization.CultureInfo.InvariantCulture);
        const expensePrev = @Model.PreviousMonthTotal.ToString(System.Globalization.CultureInfo.InvariantCulture);

        // Month labels
        const now       = new Date();
        const thisMonth = now.toLocaleString('default', { month: 'long' });
        const prevDate  = new Date(now.getFullYear(), now.getMonth() - 1, 1);
        const prevMonth = prevDate.toLocaleString('default', { month: 'long' });

        function getChartColors() {
            const dark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
            return {
                grid:          dark ? 'rgba(255,255,255,.06)' : 'rgba(15,23,42,.05)',
                ticks:         dark ? 'rgba(255,255,255,.45)' : 'rgba(15,23,42,.45)',
                tooltipBg:     dark ? 'rgba(15,23,42,.96)'   : 'rgba(255,255,255,.98)',
                tooltipBorder: dark ? 'rgba(255,255,255,.1)' : 'rgba(15,23,42,.08)',
                tooltipTitle:  dark ? '#f1f5f9' : '#0f172a',
                tooltipBody:   dark ? '#94a3b8' : '#475569'
            };
        }

        let c = getChartColors();
        const ctx = document.getElementById('dailyTrendChart').getContext('2d');

        const trendChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: [prevMonth, thisMonth],
                datasets: [
                    {
                        label: 'Income',
                        data: [0, incomeVal],
                        backgroundColor: 'rgba(16,185,129,.75)',
                        borderColor: '#10b981',
                        borderWidth: 2,
                        borderRadius: 8,
                        borderSkipped: false
                    },
                    {
                        label: 'Expenses',
                        data: [expensePrev, expenseCurr],
                        backgroundColor: ['rgba(148,163,184,.55)', 'rgba(239,68,68,.75)'],
                        borderColor: ['#94a3b8', '#ef4444'],
                        borderWidth: 2,
                        borderRadius: 8,
                        borderSkipped: false
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { intersect: false, mode: 'index' },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: c.tooltipBg,
                        titleColor: c.tooltipTitle,
                        bodyColor:  c.tooltipBody,
                        borderColor: c.tooltipBorder,
                        borderWidth: 1, padding: 12, cornerRadius: 12,
                        titleFont: { family: 'Inter', size: 13, weight: 'bold' },
                        bodyFont:  { family: 'JetBrains Mono', size: 12 },
                        callbacks: {
                            label: ctx2 => ` ${ctx2.dataset.label}: $${ctx2.parsed.y.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2})}`
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid:  { color: c.grid, drawBorder: false },
                        ticks: {
                            color: c.ticks,
                            font: { family: 'JetBrains Mono', size: 11 },
                            callback: v => '$' + v.toLocaleString()
                        }
                    },
                    x: {
                        grid:  { display: false },
                        ticks: { color: c.ticks, font: { family: 'Inter', size: 12, weight: '600' } }
                    }
                }
            }
        });

        window.addEventListener('themeChanged', () => {
            c = getChartColors();
            const s = trendChart.options.scales;
            s.y.grid.color  = c.grid;
            s.y.ticks.color = c.ticks;
            s.x.ticks.color = c.ticks;
            trendChart.options.plugins.tooltip.backgroundColor = c.tooltipBg;
            trendChart.options.plugins.tooltip.titleColor      = c.tooltipTitle;
            trendChart.options.plugins.tooltip.bodyColor       = c.tooltipBody;
            trendChart.options.plugins.tooltip.borderColor     = c.tooltipBorder;
            trendChart.update();
        });
        </text>
    }
    </script>
}

@functions {
    public string GetCategoryColor(string categoryName, int index)
    {
        var colors = new[] { "#3b82f6","#ef4444","#f59e0b","#10b981","#8b5cf6","#ec4899","#14b8a6","#f97316" };
        var name   = categoryName.ToLowerInvariant();
        if (name.Contains("food")||name.Contains("comi")||name.Contains("rest")||name.Contains("alim")) return "#ef4444";
        if (name.Contains("trans")||name.Contains("viaj")||name.Contains("auto")||name.Contains("car"))  return "#3b82f6";
        if (name.Contains("util")||name.Contains("serv")||name.Contains("luz")||name.Contains("agua"))   return "#f59e0b";
        if (name.Contains("health")||name.Contains("salu")||name.Contains("med"))                        return "#10b981";
        if (name.Contains("enter")||name.Contains("diver")||name.Contains("cine")||name.Contains("ocio"))return "#8b5cf6";
        if (name.Contains("house")||name.Contains("viv")||name.Contains("rent")||name.Contains("alqu"))  return "#ec4899";
        if (name.Contains("educ")||name.Contains("curs")||name.Contains("estu"))                         return "#6366f1";
        return colors[index % colors.Length];
    }

    public string GetCategoryIcon(string categoryName)
    {
        var name = categoryName.ToLowerInvariant();
        if (name.Contains("food")||name.Contains("comi")||name.Contains("rest")||name.Contains("alim")) return "bi-egg-fried";
        if (name.Contains("trans")||name.Contains("viaj")||name.Contains("auto")||name.Contains("car"))  return "bi-car-front";
        if (name.Contains("util")||name.Contains("serv")||name.Contains("luz")||name.Contains("agua"))   return "bi-lightning-charge";
        if (name.Contains("health")||name.Contains("salu")||name.Contains("med"))                        return "bi-heart-pulse";
        if (name.Contains("enter")||name.Contains("diver")||name.Contains("cine")||name.Contains("ocio"))return "bi-controller";
        if (name.Contains("house")||name.Contains("viv")||name.Contains("rent")||name.Contains("alqu"))  return "bi-house";
        if (name.Contains("educ")||name.Contains("curs")||name.Contains("estu"))                         return "bi-book";
        return "bi-tag";
    }
}
