@model Spendly.Web.Contracts.Dashboard.DashboardStatsDto

@{
    ViewData["Title"] = L["Dash_Title"].Value;
    var hasData = Model.TotalExpensesCount > 0;
}

<style>
    .glass-card {
        background: var(--clr-glass-card-bg);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--clr-glass-card-border);
        border-radius: 20px;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        position: relative;
        overflow: hidden;
    }
    
    .glass-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, rgba(255, 255, 255, 0.12) 0%, rgba(255, 255, 255, 0) 100%);
        pointer-events: none;
    }
    
    .glass-card:hover {
        transform: translateY(-4px);
        border-color: var(--clr-border-hover);
        box-shadow: var(--shadow-lg);
    }
    
    .stat-glow-icon {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 14px;
        font-size: 1.4rem;
        position: relative;
        z-index: 1;
    }
    
    .glow-primary {
        background: var(--glow-primary-bg);
        border: 1px solid var(--glow-primary-border);
        color: var(--glow-primary-text);
    }
    .glow-success {
        background: var(--glow-success-bg);
        border: 1px solid var(--glow-success-border);
        color: var(--glow-success-text);
    }
    .glow-danger {
        background: var(--glow-danger-bg);
        border: 1px solid var(--glow-danger-border);
        color: var(--glow-danger-text);
    }
    .glow-warning {
        background: var(--glow-warning-bg);
        border: 1px solid var(--glow-warning-border);
        color: var(--glow-warning-text);
    }
    .glow-info {
        background: var(--glow-info-bg);
        border: 1px solid var(--glow-info-border);
        color: var(--glow-info-text);
    }

    .trend-indicator {
        font-size: 0.75rem;
        padding: 0.2rem 0.5rem;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        font-weight: 600;
    }
    
    .trend-up {
        background: rgba(239, 68, 68, 0.12);
        color: #f87171;
        border: 1px solid rgba(239, 68, 68, 0.2);
    }
    .trend-down {
        background: rgba(16, 185, 129, 0.12);
        color: #34d399;
        border: 1px solid rgba(16, 185, 129, 0.2);
    }
    
    .progress-track-premium {
        height: 6px;
        background: rgba(0, 0, 0, 0.05);
        border-radius: 10px;
        overflow: hidden;
        position: relative;
    }
    [data-bs-theme="dark"] .progress-track-premium {
        background: rgba(255, 255, 255, 0.05);
    }
    
    .progress-bar-premium {
        height: 100%;
        border-radius: 10px;
        transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .category-row-premium:hover {
        background-color: rgba(0, 0, 0, 0.02) !important;
        transform: translateX(4px);
    }
    [data-bs-theme="dark"] .category-row-premium:hover {
        background-color: rgba(255, 255, 255, 0.03) !important;
    }
    
    .empty-state {
        padding: 80px 20px;
        text-align: center;
    }
    
    .empty-state-icon {
        font-size: 80px;
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.4) 0%, rgba(139, 92, 246, 0.4) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 20px;
        display: inline-block;
        filter: drop-shadow(0 0 15px rgba(59, 130, 246, 0.2));
    }
</style>

<div class="container-fluid py-4">
    @* Header *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1" style="font-family: 'Calistoga', serif; letter-spacing: -0.5px;">
                <i class="bi bi-speedometer2 text-primary me-2"></i> 
                @L["Dash_Title"]
            </h2>
            <small class="text-muted">
                <i class="bi bi-calendar3 me-1"></i> @DateTime.Now.ToString("MMMM yyyy")
            </small>
        </div>
        @if (hasData)
        {
            <a asp-controller="Expenses" asp-action="Index" class="btn btn-primary rounded-pill px-4">
                <i class="bi bi-plus-circle me-2"></i> @L["Dash_AddExpense"]
            </a>
        }
    </div>

    @if (!hasData)
    {
        @* Empty State *@
        <div class="row">
            <div class="col-12">
                <div class="card glass-card shadow-sm">
                    <div class="card-body empty-state">
                        <div class="empty-state-icon">
                            <i class="bi bi-wallet2"></i>
                        </div>
                        <h3 class="mb-3" style="font-family: 'Calistoga', serif;">@L["Dash_NoExpensesMonth"]</h3>
                        <p class="text-muted mb-4 max-w-md mx-auto">@L["Dash_StartTracking"]</p>
                        <a asp-controller="Expenses" asp-action="Index" class="btn btn-primary rounded-pill px-4 py-2">
                            <i class="bi bi-plus-circle me-2"></i>@L["Dash_AddFirstExpense"]
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        @* Stats Row *@
        <div class="row g-4 mb-4">
            <!-- Card 1: Monthly Income -->
            <div class="col-md-6 col-lg-3">
                <div class="card glass-card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <p class="text-muted mb-1 fw-semibold small text-uppercase" style="letter-spacing: 0.5px;">@L["Dash_MonthlyIncome"]</p>
                                <h3 class="mb-0 fw-bold text-success font-mono amount">@Model.CurrentMonthIncome.ToString("N2")</h3>
                            </div>
                            <div class="stat-glow-icon glow-success">
                                <i class="bi bi-cash-stack"></i>
                            </div>
                        </div>
                        <div class="d-flex align-items-center">
                            <small class="text-muted">@L["Dash_TotalEarnings"]</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card 2: Monthly Expenses -->
            <div class="col-md-6 col-lg-3">
                <div class="card glass-card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <p class="text-muted mb-1 fw-semibold small text-uppercase" style="letter-spacing: 0.5px;">@L["Dash_TotalThisMonth"]</p>
                                <h3 class="mb-0 fw-bold text-danger font-mono amount">@Model.CurrentMonthTotal.ToString("N2")</h3>
                            </div>
                            <div class="stat-glow-icon glow-danger">
                                <i class="bi bi-wallet2"></i>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2 flex-wrap mb-2">
                            @if (Model.PreviousMonthTotal > 0)
                            {
                                <span class="trend-indicator @(Model.IsIncreaseFromLastMonth ? "trend-up" : "trend-down")">
                                    <i class="bi bi-@(Model.IsIncreaseFromLastMonth ? "arrow-up" : "arrow-down") me-1"></i>
                                    @Math.Abs(Model.MonthComparisonPercentage).ToString("N1")%
                                </span>
                                <small class="text-muted">@L["Dash_VsLastMonth"]</small>
                            }
                        </div>
                        <div class="d-flex justify-content-between align-items-center border-top border-secondary border-opacity-10 pt-2 mt-2">
                            <small class="text-muted font-sans text-xs">Avg/día: <span class="font-mono fw-semibold">@Model.DailyAverage.ToString("C2")</span></small>
                            <small class="text-muted font-sans text-xs">Máx: <span class="font-mono fw-semibold">@Model.HighestExpense.ToString("C2")</span></small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card 3: Net Balance -->
            <div class="col-md-6 col-lg-3">
                <div class="card glass-card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <p class="text-muted mb-1 fw-semibold small text-uppercase" style="letter-spacing: 0.5px;">@L["Dash_Balance"]</p>
                                <h3 class="mb-0 fw-bold @(Model.MonthlyBalance >= 0 ? "text-success" : "text-danger") font-mono amount">
                                    @(Model.MonthlyBalance >= 0 ? "+" : "")@Model.MonthlyBalance.ToString("N2")
                                </h3>
                            </div>
                            <div class="stat-glow-icon @(Model.MonthlyBalance >= 0 ? "glow-success" : "glow-danger")">
                                <i class="bi bi-wallet-fill"></i>
                            </div>
                        </div>
                        <div class="d-flex align-items-center">
                            <small class="text-muted">@L["Dash_IncomeMinusExpenses"]</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card 4: Savings Rate -->
            <div class="col-md-6 col-lg-3">
                <div class="card glass-card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <p class="text-muted mb-1 fw-semibold small text-uppercase" style="letter-spacing: 0.5px;">@L["Dash_SavingsRate"]</p>
                                <h3 class="mb-0 fw-bold font-mono amount" style="color: #60a5fa;">
                                    @Model.SavingsRate.ToString("N1")%
                                </h3>
                            </div>
                            <div class="stat-glow-icon glow-info">
                                <i class="bi bi-piggy-bank"></i>
                            </div>
                        </div>
                        <div class="progress-track-premium mb-2">
                            <div class="progress-bar-premium @(Model.SavingsRate >= 20 ? "bg-success" : Model.SavingsRate >= 0 ? "bg-warning" : "bg-danger")"
                                 role="progressbar"
                                 style="width: @(Math.Max(0, Math.Min(100, Model.SavingsRate)).ToString(System.Globalization.CultureInfo.InvariantCulture))%"></div>
                        </div>
                        <div class="d-flex align-items-center justify-content-between pt-1">
                            <small class="text-muted text-truncate" style="max-width: 140px;" title="@Model.TopCategory">Top: @Model.TopCategory</small>
                            <small class="text-muted font-mono" style="font-size: 0.75rem;">@Model.TotalExpensesCount Tx</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Row 2: Spending Trend & Top 5 Expenses *@
        <div class="row g-4 mb-4">
            <div class="col-lg-8">
                <div class="card glass-card shadow-sm h-100">
                    <div class="card-header border-0 bg-transparent pt-4 pb-3">
                        <h5 class="mb-0 fw-semibold">
                            <i class="bi bi-graph-up text-primary me-2"></i>@L["Dash_SpendingTrend"]
                            <span class="badge bg-secondary bg-opacity-20 text-muted ms-2">@L["Dash_Last30Days"]</span>
                        </h5>
                    </div>
                    <div class="card-body pt-2">
                        <div style="position: relative; height: 320px; width: 100%;">
                            <canvas id="dailyTrendChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card glass-card shadow-sm h-100">
                    <div class="card-header border-0 bg-transparent pt-4 pb-3">
                        <h5 class="mb-0 fw-semibold">
                            <i class="bi bi-star-fill text-warning me-2"></i>@L["Dash_Top5Expenses"]
                        </h5>
                    </div>
                    <div class="card-body p-0">
                        @if (Model.TopExpenses.Any())
                        {
                            <div class="d-flex flex-column gap-2 p-3">
                                @foreach (var exp in Model.TopExpenses)
                                {
                                    var icon = GetCategoryIcon(exp.Category);
                                    var color = GetCategoryColor(exp.Category, 0);
                                    <div class="d-flex justify-content-between align-items-center p-3 rounded-4 category-row-premium" style="background-color: rgba(0, 0, 0, 0.015); border: 1px solid var(--clr-border); transition: all 0.2s ease;">
                                        <div class="d-flex align-items-center gap-3">
                                            <span class="d-inline-flex align-items-center justify-content-center" style="width: 40px; height: 40px; border-radius: 10px; background-color: @(color)1a; color: @color; border: 1px solid @(color)26; font-size: 1.1rem;">
                                                <i class="bi @icon"></i>
                                            </span>
                                            <div>
                                                <h6 class="mb-0 fw-semibold font-sans text-sm">@exp.Description</h6>
                                                <small class="text-muted font-sans text-xs">@exp.Date.ToString("dd MMM, yyyy")</small>
                                            </div>
                                        </div>
                                        <span class="font-mono fw-bold text-danger text-sm">
                                            -@exp.Amount.ToString("N2")
                                        </span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Row 3: Category Breakdown Table & Top Categories Progress List *@
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card glass-card shadow-sm h-100">
                    <div class="card-header border-0 bg-transparent pt-4 pb-3">
                        <h5 class="mb-0 fw-semibold">
                            <i class="bi bi-list-ul text-primary me-2"></i>@L["Dash_CategoryBreakdown"]
                        </h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle table-borderless" style="background: transparent;">
                                <thead>
                                    <tr style="border-bottom: 1px solid var(--clr-border);">
                                        <th class="py-3 ps-4 text-muted fw-semibold text-xs text-uppercase font-sans">@L["Common_Category"]</th>
                                        <th class="py-3 text-end text-muted fw-semibold text-xs text-uppercase font-sans">@L["Common_Amount"]</th>
                                        <th class="py-3 text-center text-muted fw-semibold text-xs text-uppercase font-sans">@L["Dash_Count"]</th>
                                        <th class="py-3 pe-4 text-muted fw-semibold text-xs text-uppercase font-sans" style="width: 240px">@L["Dash_OfTotal"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @{
                                    int index = 0;
                                    foreach (var cat in Model.CategoryBreakdown)
                                    {
                                        var color = GetCategoryColor(cat.Category, index++);
                                        var icon = GetCategoryIcon(cat.Category);
                                        <tr style="border-bottom: 1px solid var(--clr-border);">
                                            <td class="ps-4 py-3">
                                                <div class="d-flex align-items-center gap-2">
                                                    <span class="d-inline-flex align-items-center justify-content-center" style="width: 32px; height: 32px; border-radius: 8px; background-color: @(color)1a; color: @color; border: 1px solid @(color)26; font-size: 0.95rem;">
                                                        <i class="bi @icon"></i>
                                                    </span>
                                                    <span class="fw-medium font-sans text-sm">@cat.Category</span>
                                                </div>
                                            </td>
                                            <td class="text-end fw-bold font-mono text-sm py-3">@cat.Total.ToString("N2")</td>
                                            <td class="text-center py-3">
                                                <span class="badge bg-secondary bg-opacity-10 text-body rounded-pill px-2 py-1 font-mono" style="font-size: 0.75rem;">@cat.Count</span>
                                            </td>
                                            <td class="pe-4 py-3">
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="progress-track-premium flex-grow-1" style="height: 8px;">
                                                        <div class="progress-bar-premium" 
                                                             role="progressbar"
                                                             style="width: @cat.Percentage.ToString(System.Globalization.CultureInfo.InvariantCulture)%; background: linear-gradient(90deg, @color 0%, @(color)aa 100%);"
                                                             aria-valuenow="@cat.Percentage"
                                                             aria-valuemin="0"
                                                             aria-valuemax="100"></div>
                                                    </div>
                                                    <span class="text-muted fw-semibold font-mono text-xs" style="min-width: 35px;">
                                                        @cat.Percentage.ToString("N0")%
                                                    </span>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card glass-card shadow-sm h-100">
                    <div class="card-header border-0 bg-transparent pt-4 pb-2">
                        <h5 class="mb-0 fw-semibold">
                            <i class="bi bi-pie-chart text-primary me-2"></i>@L["Ins_Percentage"]
                        </h5>
                    </div>
                    <div class="card-body pt-2">
                        @if (Model.CategoryBreakdown.Any())
                        {
                            <div class="d-flex flex-column gap-3">
                                @for (int i = 0; i < Math.Min(5, Model.CategoryBreakdown.Count); i++)
                                {
                                    var cat = Model.CategoryBreakdown[i];
                                    var color = GetCategoryColor(cat.Category, i);
                                    var icon = GetCategoryIcon(cat.Category);
                                    <div>
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="d-inline-flex align-items-center justify-content-center" style="width: 24px; height: 24px; border-radius: 6px; background-color: @(color)1a; color: @color; border: 1px solid @(color)26; font-size: 0.8rem;">
                                                    <i class="bi @icon"></i>
                                                </span>
                                                <span class="fw-semibold font-sans text-xs">@cat.Category</span>
                                            </div>
                                            <div class="text-end">
                                                <span class="fw-bold font-mono text-xs">@cat.Total.ToString("N2")</span>
                                                <span class="text-muted font-sans text-xs ms-1">(@cat.Percentage.ToString("N0")%)</span>
                                            </div>
                                        </div>
                                        <div class="progress-track-premium" style="height: 6px;">
                                            <div class="progress-bar-premium" style="width: @cat.Percentage.ToString(System.Globalization.CultureInfo.InvariantCulture)%; background: linear-gradient(90deg, @color 0%, @(color)aa 100%);"></div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center text-muted py-5">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                No data available
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="~/lib/chart.js/chart.umd.min.js"></script>
    <script>
    @if (hasData)
    {
        <text>
            const trendData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyTrend));
            const trendCtx = document.getElementById('dailyTrendChart').getContext('2d');
            
            // Function to generate premium theme-appropriate colors
            function getChartThemeColors() {
                const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
                return {
                    grid: isDark ? 'rgba(255, 255, 255, 0.04)' : 'rgba(15, 23, 42, 0.04)',
                    ticks: isDark ? 'rgba(255, 255, 255, 0.4)' : 'rgba(15, 23, 42, 0.4)',
                    tooltipBg: isDark ? 'rgba(15, 23, 42, 0.95)' : 'rgba(255, 255, 255, 0.98)',
                    tooltipBorder: isDark ? 'rgba(255, 255, 255, 0.08)' : 'rgba(15, 23, 42, 0.08)',
                    tooltipText: isDark ? '#cbd5e1' : '#334155',
                    tooltipTitle: isDark ? '#fff' : '#0f172a'
                };
            }

            // Create linear gradient for the line area
            const gradient = trendCtx.createLinearGradient(0, 0, 0, 300);
            gradient.addColorStop(0, 'rgba(16, 185, 129, 0.35)');  // emerald green with transparency
            gradient.addColorStop(1, 'rgba(16, 185, 129, 0.01)');

            let themeColors = getChartThemeColors();

            const trendChart = new Chart(trendCtx, {
                type: 'line',
                data: {
                    labels: trendData.map(d => d.Date),
                    datasets: [{
                        label: '@L["Dash_DailySpending"].Value',
                        data: trendData.map(d => d.Amount),
                        borderColor: '#10b981', // emerald green line
                        backgroundColor: gradient,
                        fill: true,
                        tension: 0.4,
                        borderWidth: 3,
                        pointRadius: 4,
                        pointHoverRadius: 8,
                        pointBackgroundColor: '#10b981',
                        pointBorderColor: 'var(--clr-surface)',
                        pointBorderWidth: 2,
                        pointHoverBackgroundColor: '#10b981',
                        pointHoverBorderColor: 'var(--clr-surface)',
                        pointHoverBorderWidth: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        intersect: false,
                        mode: 'index'
                    },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: themeColors.tooltipBg,
                            titleColor: themeColors.tooltipTitle,
                            bodyColor: themeColors.tooltipText,
                            borderColor: themeColors.tooltipBorder,
                            borderWidth: 1,
                            padding: 12,
                            cornerRadius: 12,
                            displayColors: false,
                            titleFont: { family: 'Inter', size: 13, weight: 'bold' },
                            bodyFont: { family: 'JetBrains Mono', size: 12 },
                            callbacks: {
                                label: (ctx) => '@L["Dash_SpentLabel"].Value: ' + ctx.parsed.y.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: themeColors.grid,
                                drawBorder: false
                            },
                            ticks: {
                                color: themeColors.ticks,
                                font: { family: 'JetBrains Mono', size: 11 }
                            }
                        },
                        x: {
                            grid: { display: false },
                            ticks: {
                                color: themeColors.ticks,
                                font: { family: 'Inter', size: 11 }
                            }
                        }
                    }
                }
            });

            // Listen for theme change events to dynamically update chart colors
            window.addEventListener('themeChanged', () => {
                const colors = getChartThemeColors();
                
                trendChart.options.scales.y.grid.color = colors.grid;
                trendChart.options.scales.y.ticks.color = colors.ticks;
                trendChart.options.scales.x.ticks.color = colors.ticks;
                
                trendChart.options.plugins.tooltip.backgroundColor = colors.tooltipBg;
                trendChart.options.plugins.tooltip.titleColor = colors.tooltipTitle;
                trendChart.options.plugins.tooltip.bodyColor = colors.tooltipText;
                trendChart.options.plugins.tooltip.borderColor = colors.tooltipBorder;
                
                trendChart.update();
            });
        </text>
    }
    </script>
}

@functions {
    public string GetCategoryColor(string categoryName, int index)
    {
        var colors = new[] { "#3b82f6", "#ef4444", "#fbbf24", "#10b981", "#8b5cf6", "#ec4899", "#14b8a6", "#f97316" };
        var name = categoryName.ToLowerInvariant();
        if (name.Contains("food") || name.Contains("comi") || name.Contains("rest")) return "#ef4444"; // red
        if (name.Contains("trans") || name.Contains("viaj") || name.Contains("auto")) return "#3b82f6"; // blue
        if (name.Contains("util") || name.Contains("serv") || name.Contains("luz") || name.Contains("agua")) return "#fbbf24"; // yellow
        if (name.Contains("health") || name.Contains("salu") || name.Contains("med")) return "#10b981"; // green
        if (name.Contains("enter") || name.Contains("diver") || name.Contains("cine") || name.Contains("ocio")) return "#8b5cf6"; // purple
        if (name.Contains("house") || name.Contains("viv") || name.Contains("rent") || name.Contains("alqu")) return "#ec4899"; // pink
        if (name.Contains("educ") || name.Contains("curs") || name.Contains("estu")) return "#6366f1"; // indigo
        return colors[index % colors.Length];
    }

    public string GetCategoryIcon(string categoryName)
    {
        var name = categoryName.ToLowerInvariant();
        if (name.Contains("food") || name.Contains("comi") || name.Contains("rest")) return "bi-egg-fried";
        if (name.Contains("trans") || name.Contains("viaj") || name.Contains("auto")) return "bi-car-front";
        if (name.Contains("util") || name.Contains("serv") || name.Contains("luz") || name.Contains("agua")) return "bi-lightning-charge";
        if (name.Contains("health") || name.Contains("salu") || name.Contains("med")) return "bi-heart-pulse";
        if (name.Contains("enter") || name.Contains("diver") || name.Contains("cine") || name.Contains("ocio")) return "bi-controller";
        if (name.Contains("house") || name.Contains("viv") || name.Contains("rent") || name.Contains("alqu")) return "bi-house";
        if (name.Contains("educ") || name.Contains("curs") || name.Contains("estu")) return "bi-book";
        return "bi-tag";
    }
}
