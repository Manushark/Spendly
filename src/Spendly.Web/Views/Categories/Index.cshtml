@model List<Spendly.Web.Services.CategoryViewModel>

@{
    ViewData["Title"] = "Categories";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="bi bi-grid text-primary"></i> Categories</h2>
            <small class="text-muted">Organize your expenses with custom categories</small>
        </div>
        <button class="btn btn-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#createCategoryModal">
            <i class="bi bi-plus-lg me-1"></i> New Category
        </button>
    </div>

    @if (TempData["Error"] is string errorMsg)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-1"></i> @errorMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Any())
    {
        <div class="row g-3">
            @foreach (var cat in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-sm border-0 h-100" style="border-left: 4px solid @cat.Color !important;">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle d-flex align-items-center justify-content-center"
                                     style="width:42px; height:42px; background:@(cat.Color)15;">
                                    <i class="bi @cat.Icon" style="color:@cat.Color; font-size:1.2rem;"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold">@cat.Name</h6>
                                    @if (cat.IsDefault)
                                    {
                                        <small class="text-muted"><i class="bi bi-lock me-1"></i>Default</small>
                                    }
                                    else
                                    {
                                        <small class="text-muted">Custom</small>
                                    }
                                </div>
                            </div>
                            @if (!cat.IsDefault)
                            {
                                <div class="dropdown">
                                    <button class="btn btn-link btn-sm text-muted p-0" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                        <li>
                                            <button class="dropdown-item"
                                                    data-bs-toggle="modal" data-bs-target="#editCategoryModal-@cat.Id">
                                                <i class="bi bi-pencil me-2"></i>Edit
                                            </button>
                                        </li>
                                        <li>
                                            <form asp-action="Delete" asp-route-id="@cat.Id" method="post"
                                                  onsubmit="return confirm('Delete this category?')">
                                                @Html.AntiForgeryToken()
                                                <button class="dropdown-item text-danger" type="submit">
                                                    <i class="bi bi-trash me-2"></i>Delete
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                @* Edit Modal for each custom category *@
                @if (!cat.IsDefault)
                {
                    <div class="modal fade" id="editCategoryModal-@cat.Id" tabindex="-1">
                        <div class="modal-dialog">
                            <div class="modal-content border-0 shadow-lg">
                                <form asp-action="Update" asp-route-id="@cat.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <div class="modal-header border-0 pb-0">
                                        <h5 class="modal-title fw-bold"><i class="bi bi-pencil me-2 text-primary"></i>Edit Category</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">Name</label>
                                            <input type="text" name="Name" class="form-control" value="@cat.Name" required>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-8">
                                                <label class="form-label fw-semibold">Icon (Bootstrap Icons)</label>
                                                <select name="Icon" class="form-select">
                                                    <option value="bi-cart" selected="@(cat.Icon == "bi-cart")">🛒 Cart</option>
                                                    <option value="bi-house" selected="@(cat.Icon == "bi-house")">🏠 Home</option>
                                                    <option value="bi-car-front" selected="@(cat.Icon == "bi-car-front")">🚗 Transport</option>
                                                    <option value="bi-controller" selected="@(cat.Icon == "bi-controller")">🎮 Entertainment</option>
                                                    <option value="bi-heart-pulse" selected="@(cat.Icon == "bi-heart-pulse")">❤️ Health</option>
                                                    <option value="bi-book" selected="@(cat.Icon == "bi-book")">📚 Education</option>
                                                    <option value="bi-briefcase" selected="@(cat.Icon == "bi-briefcase")">💼 Work</option>
                                                    <option value="bi-gift" selected="@(cat.Icon == "bi-gift")">🎁 Gifts</option>
                                                    <option value="bi-tools" selected="@(cat.Icon == "bi-tools")">🔧 Services</option>
                                                    <option value="bi-three-dots" selected="@(cat.Icon == "bi-three-dots")">⋯ Other</option>
                                                </select>
                                            </div>
                                            <div class="col-4">
                                                <label class="form-label fw-semibold">Color</label>
                                                <input type="color" name="Color" class="form-control form-control-color w-100" value="@cat.Color">
                                            </div>
                                        </div>
                                    </div>
                                    <div class="modal-footer border-0 pt-0">
                                        <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                                        <button type="submit" class="btn btn-primary rounded-pill px-4">Save</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-grid fs-1 text-muted d-block mb-3 opacity-50"></i>
            <h5 class="text-muted">No categories yet</h5>
            <p class="text-muted">Create categories to organize your expenses</p>
        </div>
    }
</div>

<!-- Create Category Modal -->
<div class="modal fade" id="createCategoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle me-2 text-primary"></i>New Category</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Category Name</label>
                        <input type="text" name="Name" class="form-control" placeholder="e.g. Subscriptions" required>
                    </div>
                    <div class="row g-3">
                        <div class="col-8">
                            <label class="form-label fw-semibold">Icon</label>
                            <select name="Icon" class="form-select">
                                <option value="bi-cart">🛒 Cart / Shopping</option>
                                <option value="bi-house">🏠 Home / Rent</option>
                                <option value="bi-car-front">🚗 Transport</option>
                                <option value="bi-controller">🎮 Entertainment</option>
                                <option value="bi-heart-pulse">❤️ Health</option>
                                <option value="bi-book">📚 Education</option>
                                <option value="bi-briefcase">💼 Work</option>
                                <option value="bi-gift">🎁 Gifts</option>
                                <option value="bi-tools">🔧 Services</option>
                                <option value="bi-three-dots">⋯ Other</option>
                            </select>
                        </div>
                        <div class="col-4">
                            <label class="form-label fw-semibold">Color</label>
                            <input type="color" name="Color" class="form-control form-control-color w-100" value="#6366f1">
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">
                        <i class="bi bi-check-lg me-1"></i>Create
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
