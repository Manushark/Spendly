@model Spendly.Web.Contracts.Reports.FinancialReportDto
@{
    ViewData["Title"] = "Financial Report";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var trend        = Model.MonthlyTrend;
    var labels       = string.Join(",", trend.Select(t => $"\"{t.Month}\""));
    var expData      = string.Join(",", trend.Select(t => t.Expenses.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)));
    var incData      = string.Join(",", trend.Select(t => t.Incomes.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)));

    var catLabels    = string.Join(",", Model.CategoryBreakdown.Select(c => $"\"{c.Category}\""));
    var catData      = string.Join(",", Model.CategoryBreakdown.Select(c => c.Amount.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)));

    bool isProfit    = Model.NetBalance >= 0;
    bool canGoNext   = !(bool)ViewBag.IsCurrentMonth;
}

@section Styles {
<style>
    /* ── Page Layout ───────────────────────────────────────────── */
    .reports-page {
        padding: 2rem 1.5rem;
        max-width: 1300px;
        margin: 0 auto;
    }

    /* ── Header ─────────────────────────────────────────────────── */
    .reports-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
    }
    .reports-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--text-primary, #f1f5f9);
        margin: 0;
    }
    .reports-subtitle {
        color: var(--text-secondary, #94a3b8);
        font-size: 0.9rem;
        margin-top: 0.25rem;
    }

    /* ── Period Navigator ────────────────────────────────────────── */
    .period-nav {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: var(--card-bg, rgba(255,255,255,0.05));
        border: 1px solid var(--border-color, rgba(255,255,255,0.08));
        border-radius: 12px;
        padding: 0.5rem 1rem;
    }
    .period-nav a {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        color: var(--text-secondary, #94a3b8);
        text-decoration: none;
        transition: all 0.2s;
        font-size: 1rem;
    }
    .period-nav a:hover:not(.disabled) {
        background: var(--accent-color, #6366f1);
        color: white;
    }
    .period-nav a.disabled {
        opacity: 0.35;
        cursor: not-allowed;
        pointer-events: none;
    }
    .period-nav .period-label {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--text-primary, #f1f5f9);
        min-width: 110px;
        text-align: center;
    }

    /* ── KPI Cards ───────────────────────────────────────────────── */
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        margin-bottom: 1.75rem;
    }
    .kpi-card {
        background: var(--card-bg, rgba(255,255,255,0.04));
        border: 1px solid var(--border-color, rgba(255,255,255,0.08));
        border-radius: 16px;
        padding: 1.25rem 1.5rem;
        transition: transform 0.2s, border-color 0.2s;
    }
    .kpi-card:hover { transform: translateY(-2px); border-color: rgba(99,102,241,0.4); }
    .kpi-icon {
        font-size: 1.5rem;
        margin-bottom: 0.6rem;
    }
    .kpi-label {
        font-size: 0.78rem;
        color: var(--text-secondary, #94a3b8);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.35rem;
    }
    .kpi-value {
        font-size: 1.45rem;
        font-weight: 700;
        color: var(--text-primary, #f1f5f9);
    }
    .kpi-value.profit  { color: #34d399; }
    .kpi-value.loss    { color: #f87171; }
    .kpi-value.neutral { color: #60a5fa; }

    /* ── Charts Grid ─────────────────────────────────────────────── */
    .charts-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 1.25rem;
        margin-bottom: 1.75rem;
    }
    @@media (max-width: 900px) { .charts-grid { grid-template-columns: 1fr; } }

    .chart-card {
        background: var(--card-bg, rgba(255,255,255,0.04));
        border: 1px solid var(--border-color, rgba(255,255,255,0.08));
        border-radius: 16px;
        padding: 1.5rem;
    }
    .chart-card-title {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--text-primary, #f1f5f9);
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .chart-wrapper { position: relative; }

    /* ── Category Table ──────────────────────────────────────────── */
    .category-table-card {
        background: var(--card-bg, rgba(255,255,255,0.04));
        border: 1px solid var(--border-color, rgba(255,255,255,0.08));
        border-radius: 16px;
        padding: 1.5rem;
        overflow-x: auto;
    }
    .category-table-card table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.88rem;
    }
    .category-table-card th {
        color: var(--text-secondary, #94a3b8);
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        padding: 0.6rem 0.75rem;
        border-bottom: 1px solid var(--border-color, rgba(255,255,255,0.08));
        text-align: left;
    }
    .category-table-card td {
        padding: 0.75rem;
        color: var(--text-primary, #f1f5f9);
        border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .category-table-card tr:last-child td { border-bottom: none; }
    .progress-bar-bg {
        background: rgba(255,255,255,0.06);
        border-radius: 99px;
        height: 6px;
        overflow: hidden;
    }
    .progress-bar-fill {
        height: 100%;
        border-radius: 99px;
        background: linear-gradient(90deg, #6366f1, #a78bfa);
        transition: width 0.8s cubic-bezier(0.4,0,0.2,1);
    }
    .badge-cat {
        display: inline-block;
        padding: 0.2rem 0.6rem;
        background: rgba(99,102,241,0.15);
        color: #a78bfa;
        border-radius: 99px;
        font-size: 0.78rem;
        font-weight: 600;
    }

    /* ── Empty state ─────────────────────────────────────────────── */
    .empty-state {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--text-secondary, #94a3b8);
    }
    .empty-state .empty-icon { font-size: 3rem; margin-bottom: 1rem; }
</style>
}

<div class="reports-page">

    <!-- Header -->
    <div class="reports-header">
        <div>
            <h1 class="reports-title">📊 Financial Report</h1>
            <p class="reports-subtitle">Monthly income vs expense analysis with category breakdown.</p>
        </div>

        <!-- Period Navigator -->
        <div class="period-nav">
            <a href="@Url.Action("Index", "Reports", new { year = ViewBag.PrevYear, month = ViewBag.PrevMonth })"
               title="Previous month">&#8592;</a>

            <span class="period-label">@Model.PeriodLabel</span>

            <a href="@Url.Action("Index", "Reports", new { year = ViewBag.NextYear, month = ViewBag.NextMonth })"
               class="@(canGoNext ? "" : "disabled")"
               title="Next month">&#8594;</a>
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-icon">💸</div>
            <div class="kpi-label">Total Expenses</div>
            <div class="kpi-value loss">@Model.TotalExpenses.ToString("N2")</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon">💰</div>
            <div class="kpi-label">Total Income</div>
            <div class="kpi-value profit">@Model.TotalIncomes.ToString("N2")</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon">@(isProfit ? "📈" : "📉")</div>
            <div class="kpi-label">Net Balance</div>
            <div class="kpi-value @(isProfit ? "profit" : "loss")">
                @(isProfit ? "+" : "")@Model.NetBalance.ToString("N2")
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon">📅</div>
            <div class="kpi-label">Daily Average</div>
            <div class="kpi-value neutral">@Model.AverageDailyExpense.ToString("N2")</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon">🏆</div>
            <div class="kpi-label">Top Category</div>
            <div class="kpi-value" style="font-size:1.1rem;">@Model.TopCategory</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon">🎯</div>
            <div class="kpi-label">Expense / Income Ratio</div>
            <div class="kpi-value @(Model.ExpenseToIncomeRatio > 100 ? "loss" : "profit")">
                @Model.ExpenseToIncomeRatio.ToString("N1")%
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="charts-grid">
        <!-- Line chart: 6-month trend -->
        <div class="chart-card">
            <div class="chart-card-title">📈 6-Month Financial Trend</div>
            @if (trend.Any())
            {
                <div class="chart-wrapper" style="height:280px;">
                    <canvas id="trendChart"></canvas>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon">📭</div>
                    <p>No transaction data available for this period.</p>
                </div>
            }
        </div>

        <!-- Doughnut chart: category breakdown -->
        <div class="chart-card">
            <div class="chart-card-title">🍩 Spending by Category</div>
            @if (Model.CategoryBreakdown.Any())
            {
                <div class="chart-wrapper" style="height:280px;">
                    <canvas id="categoryChart"></canvas>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon">🗂️</div>
                    <p>No expense categories found this month.</p>
                </div>
            }
        </div>
    </div>

    <!-- Category breakdown table -->
    @if (Model.CategoryBreakdown.Any())
    {
        <div class="category-table-card">
            <div class="chart-card-title" style="margin-bottom:1.25rem;">🗂️ Category Breakdown</div>
            <table>
                <thead>
                    <tr>
                        <th>Category</th>
                        <th>Amount</th>
                        <th>Transactions</th>
                        <th style="min-width:140px;">% of Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cat in Model.CategoryBreakdown)
                    {
                        <tr>
                            <td><span class="badge-cat">@cat.Category</span></td>
                            <td>@cat.Amount.ToString("N2")</td>
                            <td>@cat.TransactionCount txn@(cat.TransactionCount != 1 ? "s" : "")</td>
                            <td>
                                <div style="display:flex;align-items:center;gap:0.5rem;">
                                    <div class="progress-bar-bg" style="flex:1;">
                                        <div class="progress-bar-fill"
                                             style="width:@cat.Percentage.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                                    </div>
                                    <span style="font-size:0.8rem;color:var(--text-secondary,#94a3b8);min-width:38px;text-align:right;">
                                        @cat.Percentage.ToString("N1")%
                                    </span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script>
    Chart.defaults.color = '#94a3b8';
    Chart.defaults.font.family = "'Inter', 'Segoe UI', sans-serif";

    // ── 6-Month Trend (Line Chart) ───────────────────────────────
    const trendCtx = document.getElementById('trendChart');
    if (trendCtx) {
        new Chart(trendCtx, {
            type: 'line',
            data: {
                labels: [@Html.Raw(labels)],
                datasets: [
                    {
                        label: 'Expenses',
                        data: [@Html.Raw(expData)],
                        borderColor: '#f87171',
                        backgroundColor: 'rgba(248,113,113,0.12)',
                        borderWidth: 2.5,
                        pointBackgroundColor: '#f87171',
                        pointRadius: 4,
                        fill: true,
                        tension: 0.4
                    },
                    {
                        label: 'Income',
                        data: [@Html.Raw(incData)],
                        borderColor: '#34d399',
                        backgroundColor: 'rgba(52,211,153,0.10)',
                        borderWidth: 2.5,
                        pointBackgroundColor: '#34d399',
                        pointRadius: 4,
                        fill: true,
                        tension: 0.4
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: {
                        labels: { color: '#94a3b8', usePointStyle: true, pointStyleWidth: 8 }
                    },
                    tooltip: {
                        backgroundColor: 'rgba(15,23,42,0.95)',
                        borderColor: 'rgba(99,102,241,0.4)',
                        borderWidth: 1,
                        callbacks: {
                            label: ctx => ` ${ctx.dataset.label}: ${Number(ctx.raw).toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2})}`
                        }
                    }
                },
                scales: {
                    x: { grid: { color: 'rgba(255,255,255,0.05)' } },
                    y: {
                        grid: { color: 'rgba(255,255,255,0.05)' },
                        ticks: {
                            callback: v => Number(v).toLocaleString()
                        }
                    }
                }
            }
        });
    }

    // ── Category Doughnut Chart ──────────────────────────────────
    const catCtx = document.getElementById('categoryChart');
    if (catCtx) {
        const palette = [
            '#6366f1','#a78bfa','#34d399','#60a5fa','#f87171',
            '#fbbf24','#f472b6','#2dd4bf','#818cf8','#fb923c'
        ];
        new Chart(catCtx, {
            type: 'doughnut',
            data: {
                labels: [@Html.Raw(catLabels)],
                datasets: [{
                    data: [@Html.Raw(catData)],
                    backgroundColor: palette.slice(0, @Model.CategoryBreakdown.Count),
                    borderColor: 'rgba(15,23,42,0.8)',
                    borderWidth: 3,
                    hoverOffset: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            color: '#94a3b8',
                            usePointStyle: true,
                            pointStyleWidth: 8,
                            padding: 12,
                            font: { size: 11 }
                        }
                    },
                    tooltip: {
                        backgroundColor: 'rgba(15,23,42,0.95)',
                        borderColor: 'rgba(99,102,241,0.4)',
                        borderWidth: 1,
                        callbacks: {
                            label: ctx => ` ${ctx.label}: ${Number(ctx.raw).toLocaleString(undefined, {minimumFractionDigits:2})} (${ctx.parsed.toFixed ? '' : ''}${((ctx.raw / [@Html.Raw(catData)].reduce((a,b)=>a+b,0))*100).toFixed(1)}%)`
                        }
                    }
                },
                cutout: '68%'
            }
        });
    }
</script>
}
