<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Spendly</title>
    <!-- Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- Optional project styles -->
    <link rel="stylesheet" href="~/Spendly.Web.styles.css" asp-append-version="true" />
</head>
<body>
    
    @{
        var isAuth = Context.Session.GetString("token") != null;
        var controller = ViewContext.RouteData.Values["Controller"]?.ToString();
    }

    @if (isAuth)
    {
        <!-- Authenticated Layout with Sidebar -->
        <div class="app-wrapper">
            
            <aside class="sidebar" id="app-sidebar">
                <div class="sidebar-header">
                    <i class="bi bi-wallet2 me-2 text-primary shadow-sm" style="color: var(--accent-color) !important;"></i> Spendly
                </div>
                
                <div class="sidebar-menu">
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Dashboard" ? "active" : "")" asp-area="" asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-grid-1x2"></i> Dashboard
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Expenses" ? "active" : "")" asp-area="" asp-controller="Expenses" asp-action="Index">
                            <i class="bi bi-receipt"></i> Expenses
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Budgets" ? "active" : "")" asp-area="" asp-controller="Budgets" asp-action="Index">
                            <i class="bi bi-pie-chart"></i> Budgets
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "RecurringExpenses" ? "active" : "")" asp-controller="RecurringExpenses" asp-action="Index">
                            <i class="bi bi-arrow-repeat"></i> Recurring
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Insights" ? "active" : "")" asp-controller="Insights" asp-action="Index">
                            <i class="bi bi-lightbulb"></i> Insights <span class="badge bg-danger ms-auto" style="font-size: 0.6rem;">PRO</span>
                        </a>
                    </div>
                </div>

                <div class="sidebar-footer">
                    <div class="user-profile">
                        <div class="user-profile-icon">
                            <i class="bi bi-person"></i>
                        </div>
                        <div class="user-profile-name">
                            <small class="text-white-50 d-block" style="font-size:0.7rem;">Logged in as</small>
                            @(Context.Session.GetString("userEmail")?.Split('@')[0] ?? "User")
                        </div>
                    </div>
                    <a class="btn-logout text-center text-decoration-none d-block" asp-controller="Auth" asp-action="Logout">
                        <i class="bi bi-box-arrow-right me-1"></i> Logout
                    </a>
                </div>
            </aside>

            <main class="main-content fade-in" id="main-content">
                <nav class="top-navbar">
                    <button class="sidebar-toggler" id="sidebar-toggle-btn">
                        <i class="bi bi-list"></i>
                    </button>
                    <!-- Here we can put breadcrumbs, title, or search in the future -->
                </nav>

                <div class="content-wrapper">
                    @RenderBody()
                </div>
            </main>

        </div>
        <!-- Ensure overlay exists for mobile sidebar closing -->
        <div class="sidebar-overlay d-none" id="sidebar-overlay" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.4); z-index: 1030;"></div>
    }
    else
    {
        <!-- Public/Visitor Layout -->
        <header>
            <nav class="navbar navbar-expand-md public-navbar py-3">
                <div class="container">
                    <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-wallet2 text-primary" style="font-size: 1.5rem;"></i>
                        <span class="fs-4">Spendly</span>
                    </a>
                    <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                        <i class="bi bi-list fs-2 text-dark"></i>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                        <ul class="navbar-nav gap-3 align-items-center">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Auth" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary rounded-pill px-4" asp-controller="Auth" asp-action="Register">Get Started</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <div class="container mt-5 fade-in">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>


    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>