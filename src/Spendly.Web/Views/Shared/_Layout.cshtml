<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Spendly</title>
    <!-- Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- Optional project styles -->
    <link rel="stylesheet" href="~/Spendly.Web.styles.css" asp-append-version="true" />
</head>
<body>
    
    @{
        var isAuth = Context.Session.GetString("token") != null;
        var controller = ViewContext.RouteData.Values["Controller"]?.ToString();
    }

    @if (isAuth)
    {
        <!-- Authenticated Layout with Sidebar -->
        <div class="app-wrapper">
            
            <aside class="sidebar" id="app-sidebar">
                <div class="sidebar-header">
                    <i class="bi bi-wallet2 me-2 text-primary shadow-sm" style="color: var(--accent-color) !important;"></i> Spendly
                </div>
                
                <div class="sidebar-menu">
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Dashboard" ? "active" : "")" asp-area="" asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-grid-1x2"></i> Dashboard
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Expenses" ? "active" : "")" asp-area="" asp-controller="Expenses" asp-action="Index">
                            <i class="bi bi-receipt"></i> Expenses
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Categories" ? "active" : "")" asp-controller="Categories" asp-action="Index">
                            <i class="bi bi-grid"></i> Categories
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Tags" ? "active" : "")" asp-controller="Tags" asp-action="Index">
                            <i class="bi bi-tags"></i> Tags
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Budgets" ? "active" : "")" asp-area="" asp-controller="Budgets" asp-action="Index">
                            <i class="bi bi-pie-chart"></i> Budgets
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "RecurringExpenses" ? "active" : "")" asp-controller="RecurringExpenses" asp-action="Index">
                            <i class="bi bi-arrow-repeat"></i> Recurring
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Incomes" ? "active" : "")" asp-controller="Incomes" asp-action="Index">
                            <i class="bi bi-cash-stack"></i> Income
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "SavingsGoals" ? "active" : "")" asp-controller="SavingsGoals" asp-action="Index">
                            <i class="bi bi-trophy"></i> Goals
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Insights" ? "active" : "")" asp-controller="Insights" asp-action="Index">
                            <i class="bi bi-lightbulb"></i> Insights
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Settings" ? "active" : "")" asp-controller="Settings" asp-action="Index">
                            <i class="bi bi-gear"></i> Settings
                        </a>
                    </div>
                </div>

                <div class="sidebar-footer">
                    <div class="user-profile">
                        <div class="user-profile-icon">
                            <i class="bi bi-person"></i>
                        </div>
                        <div class="user-profile-name">
                            <small class="text-white-50 d-block" style="font-size:0.7rem;">Logged in as</small>
                            @(Context.Session.GetString("userEmail")?.Split('@')[0] ?? "User")
                        </div>
                    </div>
                    <a class="btn-logout text-center text-decoration-none d-block" asp-controller="Auth" asp-action="Logout">
                        <i class="bi bi-box-arrow-right me-1"></i> Logout
                    </a>
                </div>
            </aside>

            <main class="main-content fade-in" id="main-content">
                <nav class="top-navbar d-flex justify-content-between align-items-center">
                    <button class="sidebar-toggler" id="sidebar-toggle-btn">
                        <i class="bi bi-list"></i>
                    </button>

                    <!-- Notification Bell -->
                    <div class="dropdown me-3">
                        <button class="btn btn-link text-dark position-relative p-0 border-0" type="button"
                                id="notificationBell" data-bs-toggle="dropdown" aria-expanded="false"
                                style="font-size: 1.3rem;">
                            <i class="bi bi-bell"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none"
                                  id="notificationBadge" style="font-size: 0.6rem;">
                                0
                            </span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end shadow-lg border-0 p-0" style="width: 360px; border-radius: 12px;" aria-labelledby="notificationBell">
                            <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                                <h6 class="mb-0 fw-bold"><i class="bi bi-bell-fill me-1 text-primary"></i> Notifications</h6>
                                <button class="btn btn-link btn-sm text-muted text-decoration-none p-0" id="markAllReadBtn">
                                    Mark all read
                                </button>
                            </div>
                            <div id="notificationList" style="max-height: 320px; overflow-y: auto;">
                                <div class="text-center py-4 text-muted">
                                    <i class="bi bi-bell-slash fs-3 d-block mb-2 opacity-50"></i>
                                    <small>No notifications</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </nav>

                <div class="content-wrapper">
                    @RenderBody()
                </div>
            </main>

        </div>
        <!-- Ensure overlay exists for mobile sidebar closing -->
        <div class="sidebar-overlay d-none" id="sidebar-overlay" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.4); z-index: 1030;"></div>
    }
    else
    {
        <!-- Public/Visitor Layout -->
        <header>
            <nav class="navbar navbar-expand-md public-navbar py-3">
                <div class="container">
                    <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-wallet2 text-primary" style="font-size: 1.5rem;"></i>
                        <span class="fs-4">Spendly</span>
                    </a>
                    <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                        <i class="bi bi-list fs-2 text-dark"></i>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                        <ul class="navbar-nav gap-3 align-items-center">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Auth" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary rounded-pill px-4" asp-controller="Auth" asp-action="Register">Get Started</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <div class="container mt-5 fade-in">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>


    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (isAuth)
    {
        <script>
            // Notification system
            document.addEventListener('DOMContentLoaded', function() {
                loadNotificationCount();
                // Refresh count every 60 seconds
                setInterval(loadNotificationCount, 60000);

                // Load notifications when dropdown opens
                const bellBtn = document.getElementById('notificationBell');
                if (bellBtn) {
                    bellBtn.addEventListener('click', loadNotifications);
                }

                // Mark all as read
                const markAllBtn = document.getElementById('markAllReadBtn');
                if (markAllBtn) {
                    markAllBtn.addEventListener('click', function(e) {
                        e.stopPropagation();
                        fetch('/Notifications/MarkAllAsRead', { method: 'POST' })
                            .then(() => {
                                loadNotificationCount();
                                loadNotifications();
                            });
                    });
                }
            });

            function loadNotificationCount() {
                fetch('/Notifications/UnreadCount')
                    .then(r => r.json())
                    .then(data => {
                        const badge = document.getElementById('notificationBadge');
                        if (badge) {
                            if (data.count > 0) {
                                badge.textContent = data.count > 99 ? '99+' : data.count;
                                badge.classList.remove('d-none');
                            } else {
                                badge.classList.add('d-none');
                            }
                        }
                    })
                    .catch(() => {});
            }

            function loadNotifications() {
                fetch('/Notifications/Recent')
                    .then(r => r.json())
                    .then(notifications => {
                        const list = document.getElementById('notificationList');
                        if (!list) return;

                        if (!notifications || notifications.length === 0) {
                            list.innerHTML = `
                                <div class="text-center py-4 text-muted">
                                    <i class="bi bi-bell-slash fs-3 d-block mb-2 opacity-50"></i>
                                    <small>No notifications</small>
                                </div>`;
                            return;
                        }

                        list.innerHTML = notifications.map(n => `
                            <div class="px-3 py-2 border-bottom ${n.isRead ? '' : 'bg-light'}" style="cursor:pointer;"
                                 onclick="markRead(${n.id}, this)">
                                <div class="d-flex align-items-start gap-2">
                                    <i class="bi ${n.type === 'BudgetExceeded' ? 'bi-exclamation-triangle-fill text-danger' : 'bi-exclamation-circle-fill text-warning'} mt-1"></i>
                                    <div class="flex-grow-1">
                                        <small class="d-block text-dark" style="line-height:1.3;">${n.message}</small>
                                        <small class="text-muted" style="font-size:0.7rem;">${timeAgo(n.createdAt)}</small>
                                    </div>
                                    ${n.isRead ? '' : '<span class="badge bg-primary rounded-circle p-1" style="width:8px;height:8px;"></span>'}
                                </div>
                            </div>
                        `).join('');
                    })
                    .catch(() => {});
            }

            function markRead(id, el) {
                fetch(`/Notifications/MarkAsRead/${id}`, { method: 'POST' })
                    .then(() => {
                        if (el) el.classList.remove('bg-light');
                        loadNotificationCount();
                    });
            }

            function timeAgo(dateStr) {
                const now = new Date();
                const date = new Date(dateStr);
                const seconds = Math.floor((now - date) / 1000);
                if (seconds < 60) return 'just now';
                const minutes = Math.floor(seconds / 60);
                if (minutes < 60) return minutes + 'm ago';
                const hours = Math.floor(minutes / 60);
                if (hours < 24) return hours + 'h ago';
                const days = Math.floor(hours / 24);
                return days + 'd ago';
            }
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>