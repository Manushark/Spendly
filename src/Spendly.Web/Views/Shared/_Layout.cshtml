<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Spendly</title>
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="~/favicon.png" />
    <link rel="shortcut icon" href="~/favicon.ico" />
    <!-- Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- Optional project styles -->
    <link rel="stylesheet" href="~/Spendly.Web.styles.css" asp-append-version="true" />
    <!-- PWA -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#6366f1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="apple-touch-icon" href="/icons/icon-192.svg">
    <style>
        @@keyframes bellShake {
            0%,100% { transform: rotate(0deg); }
            20%     { transform: rotate(-15deg); }
            40%     { transform: rotate(15deg); }
            60%     { transform: rotate(-10deg); }
            80%     { transform: rotate(10deg); }
        }
        .bell-shake { animation: bellShake 0.6s ease; }
    </style>
</head>
<body>
    
    @{
        var isAuth = Context.Session.GetString("token") != null;
        var controller = ViewContext.RouteData.Values["Controller"]?.ToString();
        var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        var currentUrl = Context.Request.Path + Context.Request.QueryString;
    }

    @if (isAuth)
    {
        <!-- Authenticated Layout with Sidebar -->
        <div class="app-wrapper">
            
            <aside class="sidebar" id="app-sidebar">
                <div class="sidebar-header">
                    <i class="bi bi-wallet2 me-2 text-primary shadow-sm" style="color: var(--accent-color) !important;"></i> Spendly
                </div>
                
                <div class="sidebar-menu">
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Dashboard" ? "active" : "")" asp-area="" asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-grid-1x2"></i> @L["Nav_Dashboard"]
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Expenses" ? "active" : "")" asp-area="" asp-controller="Expenses" asp-action="Index">
                            <i class="bi bi-receipt"></i> @L["Nav_Expenses"]
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Categories" ? "active" : "")" asp-controller="Categories" asp-action="Index">
                            <i class="bi bi-grid"></i> @L["Nav_Categories"]
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Tags" ? "active" : "")" asp-controller="Tags" asp-action="Index">
                            <i class="bi bi-tags"></i> @L["Nav_Tags"]
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Budgets" ? "active" : "")" asp-area="" asp-controller="Budgets" asp-action="Index">
                            <i class="bi bi-pie-chart"></i> @L["Nav_Budgets"]
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "RecurringExpenses" ? "active" : "")" asp-controller="RecurringExpenses" asp-action="Index">
                            <i class="bi bi-arrow-repeat"></i> @L["Nav_Recurring"]
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Incomes" ? "active" : "")" asp-controller="Incomes" asp-action="Index">
                            <i class="bi bi-cash-stack"></i> @L["Nav_Income"]
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "SavingsGoals" ? "active" : "")" asp-controller="SavingsGoals" asp-action="Index">
                            <i class="bi bi-trophy"></i> @L["Nav_Goals"]
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Insights" ? "active" : "")" asp-controller="Insights" asp-action="Index">
                            <i class="bi bi-lightbulb"></i> @L["Nav_Insights"]
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Import" ? "active" : "")" asp-controller="Import" asp-action="Index">
                            <i class="bi bi-cloud-upload"></i> @L["Nav_Import"]
                        </a>
                    </div>
                    <div class="sidebar-nav-item">
                        <a class="sidebar-link @(controller == "Settings" ? "active" : "")" asp-controller="Settings" asp-action="Index">
                            <i class="bi bi-gear"></i> @L["Nav_Settings"]
                        </a>
                    </div>
                </div>

                <div class="sidebar-footer">
                    <!-- Language Switcher -->
                    <div class="px-3 mb-2">
                        <form asp-controller="Language" asp-action="Change" method="post" class="d-flex gap-1">
                            <input type="hidden" name="returnUrl" value="@currentUrl" />
                            <button type="submit" name="culture" value="en"
                                    class="btn btn-sm flex-fill rounded-pill @(currentCulture == "en" ? "btn-primary" : "btn-outline-secondary text-white-50 border-secondary")"
                                    style="font-size: 0.75rem; padding: 2px 0;">
                                🇺🇸 EN
                            </button>
                            <button type="submit" name="culture" value="es"
                                    class="btn btn-sm flex-fill rounded-pill @(currentCulture == "es" ? "btn-primary" : "btn-outline-secondary text-white-50 border-secondary")"
                                    style="font-size: 0.75rem; padding: 2px 0;">
                                🇪🇸 ES
                            </button>
                        </form>
                    </div>

                    <div class="user-profile">
                        <div class="user-profile-icon">
                            <i class="bi bi-person"></i>
                        </div>
                        <div class="user-profile-name">
                            <small class="text-white-50 d-block" style="font-size:0.7rem;">@L["Nav_LoggedInAs"]</small>
                            @(Context.Session.GetString("userEmail")?.Split('@')[0] ?? "User")
                        </div>
                    </div>
                    <a class="btn-logout text-center text-decoration-none d-block" asp-controller="Auth" asp-action="Logout">
                        <i class="bi bi-box-arrow-right me-1"></i> @L["Nav_Logout"]
                    </a>
                </div>
            </aside>

            <main class="main-content fade-in" id="main-content">
                <nav class="top-navbar d-flex justify-content-between align-items-center">
                    <button class="sidebar-toggler" id="sidebar-toggle-btn">
                        <i class="bi bi-list"></i>
                    </button>

                    <!-- Notification Bell -->
                    <div class="dropdown me-3">
                        <button class="btn btn-link text-dark position-relative p-0 border-0" type="button"
                                id="notificationBell" data-bs-toggle="dropdown" aria-expanded="false"
                                style="font-size: 1.3rem;">
                            <i class="bi bi-bell" id="bellIcon"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none"
                                  id="notificationBadge" style="font-size: 0.6rem;">
                                0
                            </span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end shadow-lg border-0 p-0" style="width: 360px; border-radius: 12px;" aria-labelledby="notificationBell">
                            <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                                <h6 class="mb-0 fw-bold"><i class="bi bi-bell-fill me-1 text-primary"></i> @L["Nav_Notifications"]</h6>
                                <button class="btn btn-link btn-sm text-muted text-decoration-none p-0" id="markAllReadBtn">
                                    @L["Nav_MarkAllRead"]
                                </button>
                            </div>
                            <div id="notificationList" style="max-height: 320px; overflow-y: auto;">
                                <div class="text-center py-4 text-muted">
                                    <i class="bi bi-bell-slash fs-3 d-block mb-2 opacity-50"></i>
                                    <small>@L["Nav_NoNotifications"]</small>
                                </div>
                            </div>
                            <div class="border-top text-center py-2">
                                <a asp-controller="Notifications" asp-action="Index"
                                   class="btn btn-link btn-sm text-primary text-decoration-none fw-semibold">
                                    <i class="bi bi-arrow-right-circle me-1"></i>@L["Nav_SeeAllNotifications"]
                                </a>
                            </div>
                        </div>
                    </div>
                </nav>

                <div class="content-wrapper">
                    @RenderBody()
                </div>
            </main>

        </div>
        <!-- Sidebar overlay -->
        <div class="sidebar-overlay d-none" id="sidebar-overlay" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.4); z-index: 1030;"></div>

        <!-- New-notification toast -->
        <div id="notifToastContainer" class="position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
            <div id="notifToast" class="toast align-items-center text-bg-primary border-0 shadow" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi bi-bell-fill me-2"></i>@L["Notif_Toast"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Public/Visitor Layout -->
        <header>
            <nav class="navbar navbar-expand-md public-navbar py-3">
                <div class="container">
                    <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-wallet2 text-primary" style="font-size: 1.5rem;"></i>
                        <span class="fs-4">Spendly</span>
                    </a>
                    <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                        <i class="bi bi-list fs-2 text-dark"></i>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                        <ul class="navbar-nav gap-3 align-items-center">
                            <!-- Public Language Toggle -->
                            <li class="nav-item">
                                <form asp-controller="Language" asp-action="Change" method="post" class="d-flex gap-1">
                                    <input type="hidden" name="returnUrl" value="@currentUrl" />
                                    <button type="submit" name="culture" value="@(currentCulture == "en" ? "es" : "en")"
                                            class="btn btn-link nav-link p-0 border-0 text-decoration-none" title="@(currentCulture == "en" ? "Español" : "English")">
                                        <i class="bi bi-globe2 me-1"></i>@(currentCulture == "en" ? "ES" : "EN")
                                    </button>
                                </form>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Auth" asp-action="Login">@L["Nav_Login"]</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary rounded-pill px-4" asp-controller="Auth" asp-action="Register">@L["Nav_GetStarted"]</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <div class="container mt-5 fade-in">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>


    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (isAuth)
    {
        <script>
            // ── Notification System ─────────────────────────────────────────
            var _prevCount = 0;
            var _pollInterval = null;
            var _toastStr = '@L["Notif_Toast"].Value.Replace("'", "\\'")';

            // Localized time strings
            var _timeStrings = {
                justNow: '@L["Time_JustNow"].Value.Replace("'", "\\'")' ,
                mAgo:    '@L["Time_MinutesAgo"].Value.Replace("'", "\\'")' ,
                hAgo:    '@L["Time_HoursAgo"].Value.Replace("'", "\\'")' ,
                dAgo:    '@L["Time_DaysAgo"].Value.Replace("'", "\\'")' 
            };

            document.addEventListener('DOMContentLoaded', function() {
                loadNotificationCount();
                startPolling();

                // Pause polling when tab is hidden (Visibility API)
                document.addEventListener('visibilitychange', function() {
                    if (document.visibilityState === 'visible') {
                        loadNotificationCount(); // immediate refresh on focus
                        startPolling();
                    } else {
                        stopPolling();
                    }
                });

                const bellBtn = document.getElementById('notificationBell');
                if (bellBtn) bellBtn.addEventListener('click', loadNotifications);

                const markAllBtn = document.getElementById('markAllReadBtn');
                if (markAllBtn) {
                    markAllBtn.addEventListener('click', function(e) {
                        e.stopPropagation();
                        fetch('/Notifications/MarkAllAsRead', { method: 'POST' })
                            .then(() => { loadNotificationCount(); loadNotifications(); });
                    });
                }
            });

            function startPolling() {
                stopPolling();
                _pollInterval = setInterval(loadNotificationCount, 60000);
            }
            function stopPolling() {
                if (_pollInterval) { clearInterval(_pollInterval); _pollInterval = null; }
            }

            function loadNotificationCount() {
                fetch('/Notifications/UnreadCount')
                    .then(r => r.json())
                    .then(data => {
                        const badge = document.getElementById('notificationBadge');
                        if (!badge) return;

                        const newCount = data.count || 0;

                        // Show toast + animate bell on new notifications
                        if (newCount > _prevCount && _prevCount >= 0) {
                            animateBell();
                            if (_prevCount > 0) showToast(); // don't toast on first page load
                        }
                        _prevCount = newCount;

                        if (newCount > 0) {
                            badge.textContent = newCount > 99 ? '99+' : newCount;
                            badge.classList.remove('d-none');
                        } else {
                            badge.classList.add('d-none');
                        }
                    })
                    .catch(() => {});
            }

            function animateBell() {
                const bell = document.getElementById('bellIcon');
                if (!bell) return;
                bell.classList.add('bell-shake');
                setTimeout(() => bell.classList.remove('bell-shake'), 600);
            }

            function showToast() {
                const container = document.getElementById('notifToastContainer');
                if (!container) return;
                const toastEl = document.getElementById('notifToast');
                if (!toastEl) return;
                const toast = new bootstrap.Toast(toastEl, { delay: 4000 });
                toast.show();
            }

            function getNotifIcon(type) {
                switch (type) {
                    case 'BudgetExceeded':            return { icon: 'bi-exclamation-triangle-fill', color: 'text-danger' };
                    case 'BudgetWarning':             return { icon: 'bi-exclamation-circle-fill',   color: 'text-warning' };
                    case 'RecurringExpenseGenerated': return { icon: 'bi-arrow-repeat',              color: 'text-info' };
                    case 'SavingsGoalCompleted':      return { icon: 'bi-trophy-fill',               color: 'text-success' };
                    case 'SavingsGoalMilestone':      return { icon: 'bi-flag-fill',                 color: 'text-primary' };
                    default:                          return { icon: 'bi-bell-fill',                 color: 'text-secondary' };
                }
            }

            function loadNotifications() {
                var noNotifText = '@L["Nav_NoNotifications"].Value.Replace("'", "\\'")';
                fetch('/Notifications/Recent')
                    .then(r => r.json())
                    .then(notifications => {
                        const list = document.getElementById('notificationList');
                        if (!list) return;

                        if (!notifications || notifications.length === 0) {
                            list.innerHTML = `
                                <div class="text-center py-4 text-muted">
                                    <i class="bi bi-bell-slash fs-3 d-block mb-2 opacity-50"></i>
                                    <small>${noNotifText}</small>
                                </div>`;
                            return;
                        }

                        list.innerHTML = notifications.map(n => {
                            var ni = getNotifIcon(n.type);
                            return `
                            <div class="px-3 py-2 border-bottom ${n.isRead ? '' : 'bg-light'}"
                                 style="cursor:pointer; transition: background 0.35s ease;"
                                 onclick="markRead(${n.id}, this)">
                                <div class="d-flex align-items-start gap-2">
                                    <i class="bi ${ni.icon} ${ni.color} mt-1 flex-shrink-0"></i>
                                    <div class="flex-grow-1">
                                        <small class="d-block text-dark" style="line-height:1.3;">${n.message}</small>
                                        <small class="text-muted" style="font-size:0.7rem;">${timeAgo(n.createdAt)}</small>
                                    </div>
                                    ${n.isRead ? '' : '<span class="rounded-circle bg-primary flex-shrink-0" style="width:8px;height:8px;margin-top:6px;"></span>'}
                                </div>
                            </div>`;
                        }).join('');
                    })
                    .catch(() => {});
            }

            function markRead(id, el) {
                fetch(`/Notifications/MarkAsRead/${id}`, { method: 'POST' })
                    .then(() => {
                        if (el) {
                            el.classList.remove('bg-light');
                            const dot = el.querySelector('.rounded-circle.bg-primary');
                            if (dot) dot.remove();
                        }
                        loadNotificationCount();
                    });
            }

            function timeAgo(dateStr) {
                const now  = new Date();
                const date = new Date(dateStr);
                const secs = Math.floor((now - date) / 1000);
                if (secs < 60)   return _timeStrings.justNow;
                const mins = Math.floor(secs / 60);
                if (mins < 60)   return _timeStrings.mAgo.replace('{0}', mins);
                const hrs  = Math.floor(mins / 60);
                if (hrs  < 24)   return _timeStrings.hAgo.replace('{0}', hrs);
                return _timeStrings.dAgo.replace('{0}', Math.floor(hrs / 24));
            }
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)

    <!-- Service Worker Registration -->
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                    .then(reg => console.log('SW registered:', reg.scope))
                    .catch(err => console.log('SW registration failed:', err));
            });
        }
    </script>
</body>
</html>