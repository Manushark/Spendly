@{
    ViewData["Title"] = "Spendly - Smart Expense Tracking";
    var token = Context.Session.GetString("token");
}

<style>
    /* Dark Theme Base for Landing Page */
    body {
        background-color: #0B1120 !important; /* Rich Dark Background matching our theme */
        color: #ffffff;
        font-family: var(--font-body);
    }

    /* Navbar override */
    .navbar {
        background-color: transparent !important;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05) !important;
    }
    .navbar-brand, .nav-link {
        color: #fff !important;
    }

    /* Hero Section */
    .hero-section {
        position: relative;
        padding: 140px 0 100px;
        overflow: hidden;
        background: radial-gradient(circle at top right, rgba(99, 102, 241, 0.15) 0%, #0B1120 50%),
                    radial-gradient(circle at bottom left, rgba(59, 130, 246, 0.12) 0%, #0B1120 50%);
    }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-title {
        font-family: var(--font-heading);
        font-size: 4rem;
        font-weight: 800;
        line-height: 1.2;
        margin-bottom: 24px;
        background: linear-gradient(135deg, #ffffff 0%, #c7d2fe 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        letter-spacing: -1px;
    }

    .hero-subtitle {
        font-size: 1.25rem;
        color: #94a3b8;
        margin-bottom: 40px;
        font-weight: 400;
        line-height: 1.6;
    }

    /* Floating Image Animation */
    @@keyframes float {
        0% { transform: translateY(0px) rotate(0deg); }
        50% { transform: translateY(-15px) rotate(0.5deg); }
        100% { transform: translateY(0px) rotate(0deg); }
    }

    .hero-mockup-wrapper {
        position: relative;
        z-index: 2;
        animation: float 6s ease-in-out infinite;
        border-radius: 24px;
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5), 0 0 80px rgba(99, 102, 241, 0.2);
    }
    
    .hero-mockup-wrapper img {
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        width: 100%;
        display: block;
    }

    /* Glow Elements in background */
    .glow-circle {
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.4;
        z-index: 1;
    }
    .glow-1 { top: 10%; right: 10%; width: 400px; height: 400px; background: var(--clr-primary); }
    .glow-2 { bottom: 10%; left: 0; width: 300px; height: 300px; background: var(--clr-secondary); }

    /* Custom Buttons */
    .btn-glow {
        background: linear-gradient(135deg, var(--clr-primary-light) 0%, var(--clr-primary) 100%);
        color: white;
        border: none;
        border-radius: 50px;
        padding: 14px 36px;
        font-size: 1.1rem;
        font-weight: 600;
        transition: all 0.3s var(--ease-out);
        box-shadow: 0 10px 20px rgba(var(--clr-primary-rgb), 0.25);
    }

    .btn-glow:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 25px rgba(var(--clr-primary-rgb), 0.45);
        color: white;
    }

    .btn-glass {
        background: rgba(255, 255, 255, 0.04);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 50px;
        padding: 14px 36px;
        font-size: 1.1rem;
        font-weight: 600;
        transition: all 0.3s var(--ease-out);
    }
    
    .btn-glass:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.2);
        color: white;
        transform: translateY(-3px);
    }

    /* Benefits Section Glassmorphism */
    .features-section {
        padding: 100px 0;
        background-color: #0B1120;
        position: relative;
    }

    .glass-card-landing {
        background: rgba(255, 255, 255, 0.02);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-radius: 20px;
        padding: 40px 30px;
        height: 100%;
        transition: all 0.3s var(--ease-out);
        text-align: left;
    }

    .glass-card-landing:hover {
        background: rgba(255, 255, 255, 0.04);
        border-color: rgba(99, 102, 241, 0.3);
        transform: translateY(-6px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.5), inset 0 0 20px rgba(99, 102, 241, 0.05);
    }

    .feature-icon {
        width: 60px;
        height: 60px;
        background: rgba(var(--clr-primary-rgb), 0.15);
        color: var(--clr-primary-light);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        margin-bottom: 24px;
        border: 1px solid rgba(var(--clr-primary-rgb), 0.2);
    }

    /* Footer styling */
    .dark-footer {
        background-color: #070a14;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        padding: 40px 0;
    }
</style>

<!-- HERO SECTION -->
<section class="hero-section">
    <div class="glow-circle glow-1"></div>
    <div class="glow-circle glow-2"></div>
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 hero-content text-center text-lg-start">
                <h1 class="hero-title">@L["Home_HeroTitle"]</h1>
                <p class="hero-subtitle">
                    @L["Home_HeroDesc"]
                </p>
                <div class="d-flex flex-wrap gap-3 justify-content-center justify-content-lg-start">
                    @if (string.IsNullOrEmpty(token))
                    {
                        <a asp-controller="Auth" asp-action="Register" class="btn btn-glow">
                            @L["Home_CreateAccount"] <i class="bi bi-arrow-right ms-2"></i>
                        </a>
                        <a asp-controller="Auth" asp-action="Login" class="btn btn-glass">
                            @L["Auth_SignIn"]
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-glow">
                            @L["Home_OpenDashboard"] <i class="bi bi-arrow-right ms-2"></i>
                        </a>
                    }
                </div>
                
                <div class="mt-5 d-flex align-items-center justify-content-center justify-content-lg-start gap-3 opacity-75">
                    <div class="d-flex">
                        <i class="bi bi-star-fill text-warning"></i>
                        <i class="bi bi-star-fill text-warning"></i>
                        <i class="bi bi-star-fill text-warning"></i>
                        <i class="bi bi-star-fill text-warning"></i>
                        <i class="bi bi-star-fill text-warning"></i>
                    </div>
                    <span class="small text-muted">@L["Home_Trusted"]</span>
                </div>
            </div>

            <!-- MOCKUP -->
            <div class="col-lg-6">
                <div class="hero-mockup-wrapper">
                    <img src="~/images/mockup.png" alt="Spendly Platform Dashboard" class="img-fluid" />
                </div>
            </div>
        </div>
    </div>
</section>

<!-- BENEFITS SECTION -->
<section class="features-section">
    <div class="container text-center">
        <div class="mb-5 pb-3">
            <h2 class="fw-bold" style="font-family: var(--font-heading); font-size: 2.5rem; color: #fff;">@L["Home_SmarterWealth"]</h2>
            <p class="text-muted" style="font-size: 1.1rem; max-width: 600px; margin: 0 auto;">
                @L["Home_SmarterDesc"]
            </p>
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="glass-card-landing">
                    <div class="feature-icon">
                        <i class="bi bi-bar-chart-fill"></i>
                    </div>
                    <h4 class="mb-3 fw-bold text-white" style="font-family: var(--font-heading);">@L["Home_VisualAnalytics"]</h4>
                    <p class="text-muted mb-0">
                        @L["Home_VisualDesc"]
                    </p>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="glass-card-landing">
                    <div class="feature-icon">
                        <i class="bi bi-bullseye"></i>
                    </div>
                    <h4 class="mb-3 fw-bold text-white" style="font-family: var(--font-heading);">@L["Home_PrecisionBudgets"]</h4>
                    <p class="text-muted mb-0">
                        @L["Home_PrecisionDesc"]
                    </p>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="glass-card-landing">
                    <div class="feature-icon">
                        <i class="bi bi-arrow-repeat"></i>
                    </div>
                    <h4 class="mb-3 fw-bold text-white" style="font-family: var(--font-heading);">@L["Home_Automation"]</h4>
                    <p class="text-muted mb-0">
                        @L["Home_AutomationDesc"]
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CALL TO ACTION -->
<section class="py-5" style="background: linear-gradient(0deg, #070a14 0%, #0B1120 100%);">
    <div class="container">
        <div class="glass-card-landing text-center" style="padding: 60px 20px; background: rgba(99, 102, 241, 0.03); border-color: rgba(99, 102, 241, 0.15);">
            <h2 class="fw-bold text-white mb-3" style="font-family: var(--font-heading); font-size: 2.2rem;">@L["Home_CTA"]</h2>
            <p class="text-muted mb-4 fs-5">
                @L["Home_CTADesc"]
            </p>
            @if (string.IsNullOrEmpty(token))
            {
                <a asp-controller="Auth" asp-action="Register" class="btn btn-glow btn-lg px-5">
                    @L["Home_StartJourney"]
                </a>
            }
        </div>
    </div>
</section>

<!-- FOOTER -->
<footer class="dark-footer text-center">
    <div class="container">
        <div class="d-flex align-items-center justify-content-center gap-2 mb-3">
            <i class="bi bi-wallet2 text-primary fs-4"></i>
            <h5 class="mb-0 fw-bold text-white tracking-widest" style="font-family: var(--font-heading);">Spendly</h5>
        </div>
        <small class="text-muted">
            © @DateTime.Now.Year Spendly Inc. @L["Home_Footer"]
        </small>
    </div>
</footer>
