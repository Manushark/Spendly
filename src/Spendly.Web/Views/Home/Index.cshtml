@{
    ViewData["Title"] = "Home";
    var token = Context.Session.GetString("token");
}

<style>
    .hero {
        padding: 100px 0 80px;
        background: linear-gradient(135deg, var(--primary-500) 0%, var(--primary-700) 100%);
        color: white;
        text-align: center;
    }

    .hero h1 {
        font-size: 3rem;
        font-weight: 800;
        margin-bottom: var(--space-4);
        color: white;
        line-height: 1.1;
    }

    .hero p {
        font-size: 1.2rem;
        opacity: 0.9;
        color: rgba(255, 255, 255, 0.9);
        max-width: 600px;
        margin: 0 auto var(--space-8);
    }

    .btn-hero {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        background: white;
        color: var(--primary-600);
        border-radius: var(--radius-full);
        padding: var(--space-4) var(--space-8);
        font-weight: 700;
        font-size: 1rem;
        border: none;
        text-decoration: none;
        transition: all 200ms ease;
        box-shadow: var(--shadow-lg);
    }

    .btn-hero:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-xl);
        color: var(--primary-700);
    }

    .benefits-section {
        padding: 80px 0;
        background: var(--bg-primary);
    }

    .benefits-section h2 {
        font-size: 2rem;
        font-weight: 700;
        text-align: center;
        margin-bottom: var(--space-2);
        color: var(--text-primary);
    }

    .benefits-subtitle {
        text-align: center;
        color: var(--text-secondary);
        margin-bottom: var(--space-10);
        font-size: 1.05rem;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: var(--space-6);
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 var(--space-4);
    }

    .feature-card {
        background: var(--bg-elevated);
        border: 1px solid var(--border-light);
        border-radius: var(--radius-xl);
        padding: var(--space-8);
        text-align: center;
        transition: all 300ms ease;
    }

    .feature-card:hover {
        transform: translateY(-6px);
        box-shadow: var(--shadow-lg);
    }

    .feature-card .emoji {
        font-size: 2.5rem;
        margin-bottom: var(--space-4);
    }

    .feature-card h3 {
        font-size: 1.125rem;
        font-weight: 600;
        margin-bottom: var(--space-2);
        color: var(--text-primary);
    }

    .feature-card p {
        color: var(--text-secondary);
        font-size: 0.9375rem;
        line-height: 1.5;
    }

    .cta-section {
        padding: 80px 0;
        text-align: center;
        background: var(--bg-secondary);
    }

    .cta-section h3 {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: var(--space-2);
        color: var(--text-primary);
    }

    .cta-section p {
        color: var(--text-secondary);
        margin-bottom: var(--space-6);
        font-size: 1.05rem;
    }

    .btn-cta {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        background: linear-gradient(135deg, var(--primary-500), var(--primary-600));
        color: #ffffff;
        border-radius: var(--radius-lg);
        padding: var(--space-4) var(--space-8);
        font-weight: 600;
        font-size: 1rem;
        border: none;
        text-decoration: none;
        transition: all 200ms ease;
        box-shadow: var(--shadow-md);
    }

    .btn-cta:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-lg);
        color: #ffffff;
    }
</style>

<!-- HERO -->
<section class="hero">
    <div class="container">
        <h1>Toma el Control de tus Gastos</h1>
        <p>
            Rastrea tus gastos, entiende tus hábitos y toma decisiones financieras más inteligentes — todo en un solo lugar.
        </p>

        @if (string.IsNullOrEmpty(token))
        {
            <a asp-controller="Auth" asp-action="Login" class="btn-hero">
                Comenzar Gratis →
            </a>
        }
        else
        {
            <a asp-controller="Dashboard" asp-action="Index" class="btn-hero">
                Ir al Dashboard →
            </a>
        }
    </div>
</section>

<!-- BENEFITS -->
<section class="benefits-section">
    <div class="container">
        <h2>Simple. Claro. Efectivo.</h2>
        <p class="benefits-subtitle">
            Diseñado para ayudarte a enfocarte en lo que importa — tu claridad financiera.
        </p>

        <div class="features-grid">
            <div class="feature-card">
                <div class="emoji">📊</div>
                <h3>Vista Clara</h3>
                <p>
                    Ve todos tus gastos organizados y fáciles de entender de un vistazo.
                </p>
            </div>

            <div class="feature-card">
                <div class="emoji">⚡</div>
                <h3>Seguimiento Rápido</h3>
                <p>
                    Agrega y gestiona gastos en segundos sin pasos innecesarios.
                </p>
            </div>

            <div class="feature-card">
                <div class="emoji">🔒</div>
                <h3>Acceso Seguro</h3>
                <p>
                    Tus datos se mantienen privados y protegidos.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- CALL TO ACTION -->
@if (string.IsNullOrEmpty(token))
{
    <section class="cta-section">
        <div class="container">
            <h3>Empieza a gestionar tus gastos hoy</h3>
            <p>
                Construye mejores hábitos financieros con claridad y confianza.
            </p>
            <a asp-controller="Auth" asp-action="Register" class="btn-cta">
                Crear Cuenta Gratis
            </a>
        </div>
    </section>
}
