@model Spendly.Web.Contracts.Incomes.PagedIncomeResult

@{
    ViewData["Title"] = L["Inc_Title"].Value;
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="bi bi-cash-stack text-success"></i> @L["Inc_Title"]</h2>
            <small class="text-muted">@L["Inc_ManageSubtitle"]</small>
        </div>
    </div>

    @if (TempData["Error"] is string errorMsg)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Success"] is string successMsg)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@successMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        @* Main Content: Income List *@
        <div class="col-lg-8">
            @if (Model.Items.Any())
            {
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white border-0 pt-4 pb-3 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-semibold"><i class="bi bi-list-ul text-success me-2"></i>Income History</h5>
                        <small class="text-muted bg-light px-3 py-1 rounded-pill">
                            Showing
                            @((currentPage - 1) * Model.PageSize + 1)&ndash;@(Math.Min(currentPage * Model.PageSize, Model.TotalCount))
                            of @Model.TotalCount
                        </small>
                    </div>

                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="bg-light text-secondary">
                                    <tr>
                                        <th class="border-0 ps-4 py-3">@L["Common_Source"]</th>
                                        <th class="border-0 py-3">@L["Common_Amount"]</th>
                                        <th class="border-0 py-3">@L["Common_Description"]</th>
                                        <th class="border-0 py-3">@L["Common_Date"]</th>
                                        <th class="border-0 py-3 text-center">@L["Inc_IsRecurring"]</th>
                                        <th class="border-0 py-3 text-center pe-4" style="width:110px">@L["Common_Actions"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var income in Model.Items)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-medium text-dark">
                                                <i class="bi bi-bank me-1 text-success opacity-50"></i>@income.Source
                                            </td>
                                            <td class="text-success fw-bold">+$@income.Amount.ToString("N2")</td>
                                            <td class="text-muted">
                                                <small>@(income.Description ?? "—")</small>
                                            </td>
                                            <td class="text-muted"><small>@income.Date.ToString("MMM dd, yyyy")</small></td>
                                            <td class="text-center">
                                                @if (income.IsRecurring)
                                                {
                                                    <span class="badge bg-info bg-opacity-10 text-info px-2 py-1">
                                                        <i class="bi bi-arrow-repeat me-1"></i>Yes
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary bg-opacity-10 text-muted px-2 py-1">No</span>
                                                }
                                            </td>
                                            <td class="text-center pe-4">
                                                <a asp-action="Edit" asp-route-id="@income.Id"
                                                   class="btn btn-sm btn-light text-primary me-1" title="@L["Common_Edit"]">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <form asp-action="Delete" asp-route-id="@income.Id"
                                                      method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-light text-danger"
                                                            title="@L["Common_Delete"]"
                                                            onclick="return confirm('@L["Inc_DeleteConfirm"].Value');">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    @* Pagination *@
                    @if (Model.TotalPages > 1)
                    {
                        <div class="card-footer bg-white border-top-0 pt-4 pb-4">
                            <nav aria-label="Income pagination">
                                <ul class="pagination pagination-sm mb-0 justify-content-center">
                                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                                        <a class="page-link border-0 text-dark fw-bold"
                                           asp-action="Index" asp-route-page="@(currentPage - 1)">
                                            <i class="bi bi-chevron-left"></i>
                                        </a>
                                    </li>
                                    @{
                                        int start = Math.Max(1, currentPage - 2);
                                        int end = Math.Min(Model.TotalPages, currentPage + 2);
                                    }
                                    @for (int p = start; p <= end; p++)
                                    {
                                        <li class="page-item @(p == currentPage ? "active" : "")">
                                            <a class="page-link border-0 mx-1 rounded-circle @(p == currentPage ? "shadow-sm" : "bg-transparent text-dark")"
                                               style="width:32px; height:32px; display:inline-flex; align-items:center; justify-content:center;"
                                               asp-action="Index" asp-route-page="@p">@p</a>
                                        </li>
                                    }
                                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                                        <a class="page-link border-0 text-dark fw-bold"
                                           asp-action="Index" asp-route-page="@(currentPage + 1)">
                                            <i class="bi bi-chevron-right"></i>
                                        </a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert bg-white shadow-sm border-0 d-flex align-items-center p-4" style="border-radius: 12px;">
                    <div class="text-success fs-1 me-4 opacity-50"><i class="bi bi-cash-stack"></i></div>
                    <div>
                        <h5 class="mb-1 fw-bold">@L["Inc_NoIncome"]</h5>
                        <p class="mb-0 text-muted">@L["Inc_AddFirst"]</p>
                    </div>
                </div>
            }
        </div>

        @* Right Sidebar: Add Income Form *@
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 position-sticky" style="top: 20px; border-radius: 16px;">
                <div class="card-header bg-white border-0 pt-4 pb-0 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center bg-success bg-opacity-10 text-success rounded-circle mb-3" style="width: 50px; height: 50px; font-size: 1.5rem;">
                        <i class="bi bi-plus-lg"></i>
                    </div>
                    <h5 class="mb-0 fw-bold">@L["Inc_NewIncome"]</h5>
                    <p class="text-muted small">Record a new earning</p>
                </div>
                <div class="card-body p-4 pt-2">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-semibold text-uppercase">@L["Common_Amount"]</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-currency-dollar"></i></span>
                                <input name="Amount" type="number" step="0.01" min="0.01"
                                       class="form-control border-start-0 ps-0 form-control-lg fw-bold text-success" placeholder="@L["Ph_Zero"]" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-semibold text-uppercase">@L["Common_Source"]</label>
                            <input name="Source" class="form-control"
                                   placeholder="@L["Ph_IncomeSource"]" required maxlength="100" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-semibold text-uppercase">@L["Common_Description"] (@L["Common_Optional"])</label>
                            <input name="Description" class="form-control"
                                   placeholder="@L["Ph_IncomeDesc"]" maxlength="200" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-semibold text-uppercase">@L["Common_Date"]</label>
                            <input name="Date" type="date" class="form-control" required
                                   max="@DateTime.Today.ToString("yyyy-MM-dd")" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>

                        <div class="mb-4">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="IsRecurring" value="true" id="isRecurringSwitch">
                                <label class="form-check-label text-muted small" for="isRecurringSwitch">
                                    <i class="bi bi-arrow-repeat me-1"></i>This is recurring income
                                </label>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-success w-100 py-3 rounded-3 fw-bold shadow-sm">
                            <i class="bi bi-plus-circle me-1"></i> @L["Inc_NewIncome"]
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
