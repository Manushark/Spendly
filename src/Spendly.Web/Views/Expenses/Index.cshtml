@model Spendly.Web.Contracts.Expenses.PagedExpenseResult

@{
    ViewData["Title"] = "My Expenses";
    var currentCategory = ViewBag.Category as string;
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="bi bi-receipt text-primary"></i> My Expenses</h2>
            <small class="text-muted">Manage your transactions</small>
        </div>
    </div>
    @* Error / success alerts *@
    @if (TempData["Error"] is string errorMsg)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Success"] is string successMsg)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@successMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        @* ── Main Content: Filters & Expense List (Left Column) ── *@
        <div class="col-lg-8">
            
            @* Filter bar *@
            <div class="card mb-4 border-0 bg-light shadow-sm" style="border-radius: 12px;">
                <div class="card-body py-3 px-4">
                    <form asp-action="Index" method="get" class="row g-2 align-items-center">
                        <div class="col-auto">
                            <label class="col-form-label fw-semibold text-muted">Filter by Category:</label>
                        </div>
                        <div class="col-md-5 col-12">
                            <input type="text" name="category" value="@currentCategory"
                                   class="form-control"
                                   placeholder="e.g. Food, Transport…" />
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-primary px-3">
                                <i class="bi bi-search"></i>
                            </button>
                            @if (!string.IsNullOrEmpty(currentCategory))
                            {
                                <a asp-action="Index" class="btn btn-outline-secondary ms-1 px-3">
                                    <i class="bi bi-x-lg"></i>
                                </a>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(currentCategory))
                        {
                            <div class="col-auto ms-auto">
                                <span class="badge bg-primary px-3 py-2">Searching: @currentCategory</span>
                            </div>
                        }
                    </form>
                </div>
            </div>

            @* Expense list *@
            @if (Model.Items.Any())
            {
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white border-0 pt-4 pb-3 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-semibold"><i class="bi bi-list-ul text-primary me-2"></i>Recent Transactions</h5>
                        <small class="text-muted bg-light px-3 py-1 rounded-pill">
                            Showing
                            @((currentPage - 1) * Model.PageSize + 1)–@(Math.Min(currentPage * Model.PageSize, Model.TotalCount))
                            of @Model.TotalCount
                        </small>
                    </div>

                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="bg-light text-secondary">
                                    <tr>
                                        <th class="border-0 ps-4 py-3">Description</th>
                                        <th class="border-0 py-3">Amount</th>
                                        <th class="border-0 py-3">Category</th>
                                        <th class="border-0 py-3">Date</th>
                                        <th class="border-0 py-3 text-center pe-4" style="width:110px">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var e in Model.Items)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-medium text-dark">@e.Description</td>
                                            <td class="text-danger fw-bold">-$@e.Amount.ToString("N2")</td>
                                            <td><span class="badge bg-secondary bg-opacity-10 text-dark px-2 py-1"><i class="bi bi-tag-fill me-1 opacity-50"></i>@e.Category</span></td>
                                            <td class="text-muted"><small>@e.Date.ToString("MMM dd, yyyy")</small></td>
                                            <td class="text-center pe-4">
                                                <a asp-action="Edit" asp-route-id="@e.Id"
                                                   class="btn btn-sm btn-light text-primary me-1"
                                                   title="Edit">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <form asp-action="Delete" asp-route-id="@e.Id"
                                                      method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-light text-danger"
                                                            title="Delete"
                                                            onclick="return confirm('Delete this expense?');">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    @* Pagination *@
                    @if (Model.TotalPages > 1)
                    {
                        <div class="card-footer bg-white border-top-0 pt-4 pb-4">
                            <nav aria-label="Expenses pagination">
                                <ul class="pagination pagination-sm mb-0 justify-content-center">

                                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                                        <a class="page-link border-0 text-dark fw-bold"
                                           asp-action="Index"
                                           asp-route-page="@(currentPage - 1)"
                                           asp-route-category="@currentCategory"
                                           tabindex="@(!Model.HasPreviousPage ? -1 : 0)">
                                            <i class="bi bi-chevron-left"></i>
                                        </a>
                                    </li>

                                    @{
                                        int start = Math.Max(1, currentPage - 2);
                                        int end = Math.Min(Model.TotalPages, currentPage + 2);
                                    }
                                    @for (int p = start; p <= end; p++)
                                    {
                                        <li class="page-item @(p == currentPage ? "active" : "")">
                                            <a class="page-link border-0 mx-1 rounded-circle @(p == currentPage ? "shadow-sm" : "bg-transparent text-dark")" style="width:32px; height:32px; display:inline-flex; align-items:center; justify-content:center;"
                                               asp-action="Index"
                                               asp-route-page="@p"
                                               asp-route-category="@currentCategory">@p</a>
                                        </li>
                                    }

                                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                                        <a class="page-link border-0 text-dark fw-bold"
                                           asp-action="Index"
                                           asp-route-page="@(currentPage + 1)"
                                           asp-route-category="@currentCategory"
                                           tabindex="@(!Model.HasNextPage ? -1 : 0)">
                                            <i class="bi bi-chevron-right"></i>
                                        </a>
                                    </li>

                                </ul>
                            </nav>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert bg-white shadow-sm border-0 d-flex align-items-center p-4" style="border-radius: 12px;">
                    <div class="text-primary fs-1 me-4 opacity-50"><i class="bi bi-inbox"></i></div>
                    <div>
                        <h5 class="mb-1 fw-bold">No expenses found</h5>
                        @if (!string.IsNullOrEmpty(currentCategory))
                        {
                            <p class="mb-0 text-muted">No transactions matched the category <strong>@currentCategory</strong>.</p>
                        }
                        else
                        {
                            <p class="mb-0 text-muted">You haven't recorded any expenses yet. Use the panel on the right to add one.</p>
                        }
                    </div>
                </div>
            }
        </div>

        @* ── Right Sidebar: Add Expense Form (Right Column) ── *@
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 position-sticky" style="top: 20px; border-radius: 16px;">
                <div class="card-header bg-white border-0 pt-4 pb-0 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle mb-3" style="width: 50px; height: 50px; font-size: 1.5rem;">
                        <i class="bi bi-plus-lg"></i>
                    </div>
                    <h5 class="mb-0 fw-bold">Quick Add</h5>
                    <p class="text-muted small">Record a new expense</p>
                </div>
                <div class="card-body p-4 pt-2">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-3">
                            <label class="form-label text-muted small fw-semibold text-uppercase">Amount ($)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-currency-dollar"></i></span>
                                <input name="Amount" type="number" step="0.01" min="0.01"
                                       class="form-control border-start-0 ps-0 form-control-lg fw-bold text-primary" placeholder="0.00" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-semibold text-uppercase">Description</label>
                            <input name="Description" class="form-control"
                                   placeholder="e.g. Coffee, Taxi..." required maxlength="200" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-semibold text-uppercase">Category</label>
                            <input name="Category" class="form-control"
                                   placeholder="e.g. Food" required maxlength="100" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-muted small fw-semibold text-uppercase">Date</label>
                            <input name="Date" type="date" class="form-control" required
                                   max="@DateTime.Today.ToString("yyyy-MM-dd")" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-bold shadow-sm">
                            Add Transaction
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}