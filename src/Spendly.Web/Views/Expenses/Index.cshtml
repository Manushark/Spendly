@model Spendly.Web.Contracts.Expenses.PagedExpenseResult
@using Spendly.Web.Services

@{
    ViewData["Title"] = L["Exp_Title"].Value;
    var currentCategory = ViewBag.Category as string;
    var currentSearch = ViewBag.Search as string;
    var dateFrom = ViewBag.DateFrom as DateTime?;
    var dateTo = ViewBag.DateTo as DateTime?;
    var minAmount = ViewBag.MinAmount as decimal?;
    var maxAmount = ViewBag.MaxAmount as decimal?;
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var categories = ViewBag.Categories as List<CategoryViewModel> ?? new List<CategoryViewModel>();
    var hasActiveFilters = !string.IsNullOrEmpty(currentCategory) || !string.IsNullOrEmpty(currentSearch)
        || dateFrom.HasValue || dateTo.HasValue || minAmount.HasValue || maxAmount.HasValue;
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="bi bi-receipt text-primary"></i> @L["Exp_Title"]</h2>
            <small class="text-muted">@L["Exp_TrackSubtitle"]</small>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="ExportCsv"
               asp-route-category="@currentCategory"
               asp-route-dateFrom="@(dateFrom?.ToString("yyyy-MM-dd"))"
               asp-route-dateTo="@(dateTo?.ToString("yyyy-MM-dd"))"
               class="btn btn-outline-success btn-sm rounded-pill px-3">
                <i class="bi bi-file-earmark-spreadsheet me-1"></i> Export CSV
            </a>
            <a asp-action="ExportReport" target="_blank"
               class="btn btn-outline-primary btn-sm rounded-pill px-3">
                <i class="bi bi-file-earmark-pdf me-1"></i> Monthly Report
            </a>
        </div>
    </div>

    @if (TempData["Error"] is string errorMsg)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Success"] is string successMsg)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@successMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        @* Main Content: Filters & Expense List *@
        <div class="col-lg-8">

            @* Advanced Filter Bar *@
            <div class="card mb-4 border-0 bg-light shadow-sm" style="border-radius: 12px;">
                <div class="card-body py-3 px-4">
                    <form asp-action="Index" method="get">
                        @* Search & Category Row *@
                        <div class="row g-2 align-items-end mb-2">
                            <div class="col-md-5">
                                <label class="form-label text-muted small fw-semibold mb-1">@L["Common_Search"]</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                                    <input type="text" name="search" value="@currentSearch"
                                           class="form-control border-start-0 ps-0"
                                           placeholder="Search description..." />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted small fw-semibold mb-1">@L["Common_Category"]</label>
                                <select name="category" class="form-select" style="border-radius:10px; padding:10px 15px;">
                                    <option value="">@L["Exp_AllCategories"]</option>
                                    @foreach (var cat in categories)
                                    {
                                        <option value="@cat.Name" selected="@(currentCategory == cat.Name)">
                                            @cat.Name
                                        </option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3 d-flex gap-1">
                                <button type="submit" class="btn btn-primary flex-grow-1">
                                    <i class="bi bi-funnel"></i> @L["Common_Filter"]
                                </button>
                                @if (hasActiveFilters)
                                {
                                    <a asp-action="Index" class="btn btn-outline-secondary">
                                        <i class="bi bi-x-lg"></i>
                                    </a>
                                }
                            </div>
                        </div>

                        @* Collapsible Advanced Filters *@
                        <div class="collapse @(dateFrom.HasValue || dateTo.HasValue || minAmount.HasValue || maxAmount.HasValue ? "show" : "")"
                             id="advancedFilters">
                            <hr class="my-2 opacity-25" />
                            <div class="row g-2">
                                <div class="col-md-3">
                                    <label class="form-label text-muted small fw-semibold mb-1">@L["Common_Date"]</label>
                                    <input type="date" name="dateFrom" class="form-control"
                                           value="@(dateFrom?.ToString("yyyy-MM-dd"))" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small fw-semibold mb-1">@L["Common_Date"]</label>
                                    <input type="date" name="dateTo" class="form-control"
                                           value="@(dateTo?.ToString("yyyy-MM-dd"))" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small fw-semibold mb-1">@L["Exp_MinAmount"]</label>
                                    <input type="number" name="minAmount" step="0.01" min="0"
                                           class="form-control" placeholder="$0"
                                           value="@minAmount" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small fw-semibold mb-1">@L["Exp_MaxAmount"]</label>
                                    <input type="number" name="maxAmount" step="0.01" min="0"
                                           class="form-control" placeholder="$999"
                                           value="@maxAmount" />
                                </div>
                            </div>
                        </div>

                        <div class="text-center mt-2">
                            <button class="btn btn-link btn-sm text-muted text-decoration-none p-0"
                                    type="button" data-bs-toggle="collapse" data-bs-target="#advancedFilters">
                                <i class="bi bi-sliders2 me-1"></i>
                                Advanced Filters
                                <i class="bi bi-chevron-down ms-1" style="font-size:0.7rem;"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @* Active Filters Badges *@
            @if (hasActiveFilters)
            {
                <div class="d-flex flex-wrap gap-2 mb-3">
                    @if (!string.IsNullOrEmpty(currentSearch))
                    {
                        <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill">
                            <i class="bi bi-search me-1"></i> "@currentSearch"
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(currentCategory))
                    {
                        <span class="badge bg-info bg-opacity-10 text-info px-3 py-2 rounded-pill">
                            <i class="bi bi-tag me-1"></i> @currentCategory
                        </span>
                    }
                    @if (dateFrom.HasValue || dateTo.HasValue)
                    {
                        <span class="badge bg-warning bg-opacity-10 text-warning px-3 py-2 rounded-pill">
                            <i class="bi bi-calendar me-1"></i>
                            @(dateFrom?.ToString("MMM dd") ?? "...") - @(dateTo?.ToString("MMM dd") ?? "...")
                        </span>
                    }
                    @if (minAmount.HasValue || maxAmount.HasValue)
                    {
                        <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill">
                            <i class="bi bi-currency-dollar me-1"></i>
                            $@(minAmount?.ToString("N0") ?? "0") - $@(maxAmount?.ToString("N0") ?? "...")
                        </span>
                    }
                </div>
            }

            @* Expense list *@
            @if (Model.Items.Any())
            {
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white border-0 pt-4 pb-3 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-semibold"><i class="bi bi-list-ul text-primary me-2"></i>@L["Exp_Showing"]</h5>
                        <small class="text-muted bg-light px-3 py-1 rounded-pill">
                            @L["Exp_Showing"]
                            @((currentPage - 1) * Model.PageSize + 1)&ndash;@(Math.Min(currentPage * Model.PageSize, Model.TotalCount))
                            of @Model.TotalCount
                        </small>
                    </div>

                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="bg-light text-secondary">
                                    <tr>
                                        <th class="border-0 ps-4 py-3">@L["Common_Description"]</th>
                                        <th class="border-0 py-3">@L["Common_Amount"]</th>
                                        <th class="border-0 py-3">@L["Common_Category"]</th>
                                        <th class="border-0 py-3">@L["Common_Date"]</th>
                                        <th class="border-0 py-3 text-center pe-4" style="width:110px">@L["Common_Actions"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var e in Model.Items)
                                    {
                                        var matchedCat = categories.FirstOrDefault(c => c.Name == e.Category);
                                        <tr>
                                            <td class="ps-4 fw-medium text-dark">@e.Description</td>
                                            <td class="text-danger fw-bold">-$@e.Amount.ToString("N2")</td>
                                            <td>
                                                @if (matchedCat != null)
                                                {
                                                    <span class="badge px-2 py-1" style="background: @(matchedCat.Color)20; color: @matchedCat.Color; border: 1px solid @(matchedCat.Color)40;">
                                                        <i class="bi @matchedCat.Icon me-1"></i>@e.Category
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary bg-opacity-10 text-dark px-2 py-1">
                                                        <i class="bi bi-tag-fill me-1 opacity-50"></i>@e.Category
                                                    </span>
                                                }
                                            </td>
                                            <td class="text-muted"><small>@e.Date.ToString("MMM dd, yyyy")</small></td>
                                            <td class="text-center pe-4">
                                                <a asp-action="Edit" asp-route-id="@e.Id"
                                                   class="btn btn-sm btn-light text-primary me-1"
                                                   title="Edit">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <form asp-action="Delete" asp-route-id="@e.Id"
                                                      method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-light text-danger"
                                                            title="Delete"
                                                            onclick="return confirm('@L["Exp_DeleteConfirm"].Value');">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    @* Pagination *@
                    @if (Model.TotalPages > 1)
                    {
                        <div class="card-footer bg-white border-top-0 pt-4 pb-4">
                            <nav aria-label="Expenses pagination">
                                <ul class="pagination pagination-sm mb-0 justify-content-center">
                                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                                        <a class="page-link border-0 text-dark fw-bold"
                                           asp-action="Index"
                                           asp-route-page="@(currentPage - 1)"
                                           asp-route-category="@currentCategory"
                                           asp-route-search="@currentSearch"
                                           asp-route-dateFrom="@(dateFrom?.ToString("yyyy-MM-dd"))"
                                           asp-route-dateTo="@(dateTo?.ToString("yyyy-MM-dd"))"
                                           asp-route-minAmount="@minAmount"
                                           asp-route-maxAmount="@maxAmount"
                                           tabindex="@(!Model.HasPreviousPage ? -1 : 0)">
                                            <i class="bi bi-chevron-left"></i>
                                        </a>
                                    </li>

                                    @{
                                        int start = Math.Max(1, currentPage - 2);
                                        int end = Math.Min(Model.TotalPages, currentPage + 2);
                                    }
                                    @for (int p = start; p <= end; p++)
                                    {
                                        <li class="page-item @(p == currentPage ? "active" : "")">
                                            <a class="page-link border-0 mx-1 rounded-circle @(p == currentPage ? "shadow-sm" : "bg-transparent text-dark")"
                                               style="width:32px; height:32px; display:inline-flex; align-items:center; justify-content:center;"
                                               asp-action="Index"
                                               asp-route-page="@p"
                                               asp-route-category="@currentCategory"
                                               asp-route-search="@currentSearch"
                                               asp-route-dateFrom="@(dateFrom?.ToString("yyyy-MM-dd"))"
                                               asp-route-dateTo="@(dateTo?.ToString("yyyy-MM-dd"))"
                                               asp-route-minAmount="@minAmount"
                                               asp-route-maxAmount="@maxAmount">@p</a>
                                        </li>
                                    }

                                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                                        <a class="page-link border-0 text-dark fw-bold"
                                           asp-action="Index"
                                           asp-route-page="@(currentPage + 1)"
                                           asp-route-category="@currentCategory"
                                           asp-route-search="@currentSearch"
                                           asp-route-dateFrom="@(dateFrom?.ToString("yyyy-MM-dd"))"
                                           asp-route-dateTo="@(dateTo?.ToString("yyyy-MM-dd"))"
                                           asp-route-minAmount="@minAmount"
                                           asp-route-maxAmount="@maxAmount"
                                           tabindex="@(!Model.HasNextPage ? -1 : 0)">
                                            <i class="bi bi-chevron-right"></i>
                                        </a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert bg-white shadow-sm border-0 d-flex align-items-center p-4" style="border-radius: 12px;">
                    <div class="text-primary fs-1 me-4 opacity-50"><i class="bi bi-inbox"></i></div>
                    <div>
                        <h5 class="mb-1 fw-bold">@L["Exp_NoExpenses"]</h5>
                        @if (hasActiveFilters)
                        {
                            <p class="mb-0 text-muted">No transactions matched your filters. Try adjusting them.</p>
                        }
                        else
                        {
                            <p class="mb-0 text-muted">You haven't recorded any expenses yet. Use the panel on the right to add one.</p>
                        }
                    </div>
                </div>
            }
        </div>

        @* Right Sidebar: Add Expense Form *@
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 position-sticky" style="top: 20px; border-radius: 16px;">
                <div class="card-header bg-white border-0 pt-4 pb-0 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle mb-3" style="width: 50px; height: 50px; font-size: 1.5rem;">
                        <i class="bi bi-plus-lg"></i>
                    </div>
                    <h5 class="mb-0 fw-bold">@L["Exp_NewExpense"]</h5>
                    <p class="text-muted small">@L["Exp_TrackSubtitle"]</p>
                </div>
                <div class="card-body p-4 pt-2">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-semibold text-uppercase">@L["Common_Amount"]</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-currency-dollar"></i></span>
                                <input name="Amount" type="number" step="0.01" min="0.01"
                                       class="form-control border-start-0 ps-0 form-control-lg fw-bold text-primary" placeholder="0.00" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-semibold text-uppercase">@L["Common_Description"]</label>
                            <input name="Description" class="form-control"
                                   placeholder="e.g. Coffee, Taxi..." required maxlength="200" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-semibold text-uppercase">@L["Common_Category"]</label>
                            @if (categories.Any())
                            {
                                <select name="Category" class="form-select" required style="border-radius:10px; padding:12px 15px;">
                                    <option value="" disabled selected>Select a category</option>
                                    @foreach (var cat in categories)
                                    {
                                        <option value="@cat.Name">@cat.Name</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input name="Category" class="form-control"
                                       placeholder="e.g. Food" required maxlength="100" />
                            }
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-muted small fw-semibold text-uppercase">@L["Common_Date"]</label>
                            <input name="Date" type="date" class="form-control" required
                                   max="@DateTime.Today.ToString("yyyy-MM-dd")" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-bold shadow-sm">
                            @L["Exp_NewExpense"]
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}