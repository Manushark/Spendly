@model Spendly.Web.Contracts.Auth.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Spendly</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Modern Design CSS -->
    <link rel="stylesheet" href="~/css/modern-design.css" />

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: var(--font-body);
            background: var(--bg-primary);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .auth-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            max-width: 1200px;
            width: 100%;
            min-height: 600px;
            background: var(--bg-elevated);
            border-radius: var(--radius-2xl);
            overflow: hidden;
            box-shadow: var(--shadow-2xl);
        }

        /* Left Side - Login Form */
        .auth-main {
            padding: var(--space-12);
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .auth-header {
            margin-bottom: var(--space-8);
        }

        .auth-header h1 {
            font-size: 2rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: var(--space-2);
        }

        .auth-header p {
            color: var(--text-secondary);
            font-size: 0.9375rem;
        }

        /* Google Login Button */
        .google-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: var(--space-3);
            width: 100%;
            padding: var(--space-4);
            border: 1px solid var(--border-secondary);
            border-radius: var(--radius-lg);
            background: var(--bg-primary);
            color: var(--text-primary);
            font-weight: 600;
            font-size: 0.9375rem;
            cursor: pointer;
            transition: all 150ms ease;
            text-decoration: none;
        }

        .google-btn:hover {
            background: var(--bg-secondary);
            border-color: var(--border-primary);
            transform: translateY(-1px);
            box-shadow: var(--shadow-md);
        }

        .google-icon {
            width: 20px;
            height: 20px;
        }

        .divider {
            display: flex;
            align-items: center;
            gap: var(--space-4);
            margin: var(--space-6) 0;
            color: var(--text-tertiary);
            font-size: 0.875rem;
        }

        .divider::before,
        .divider::after {
            content: "";
            flex: 1;
            height: 1px;
            background: var(--border-secondary);
        }

        /* Traditional Login Form */
        .auth-form {
            display: flex;
            flex-direction: column;
            gap: var(--space-4);
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: var(--space-2);
        }

        .form-group label {
            font-weight: 500;
            font-size: 0.875rem;
            color: var(--text-secondary);
        }

        .form-group input {
            padding: var(--space-3);
            border: 1px solid var(--border-secondary);
            border-radius: var(--radius-md);
            background: var(--bg-primary);
            color: var(--text-primary);
            font-size: 0.9375rem;
            transition: all 150ms ease;
        }

        .form-group input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
        }

        .form-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: var(--space-2);
        }

        .remember-me {
            display: flex;
            align-items: center;
            gap: var(--space-2);
            font-size: 0.875rem;
            color: var(--text-secondary);
        }

        .forgot-password {
            font-size: 0.875rem;
            color: var(--primary);
            text-decoration: none;
            font-weight: 500;
        }

        .forgot-password:hover {
            text-decoration: underline;
        }

        .submit-btn {
            width: 100%;
            padding: var(--space-4);
            background: linear-gradient(135deg, var(--primary) 0%, #4f46e5 100%);
            color: white;
            border: none;
            border-radius: var(--radius-lg);
            font-weight: 600;
            font-size: 0.9375rem;
            cursor: pointer;
            transition: all 150ms ease;
            margin-top: var(--space-4);
        }

        .submit-btn:hover {
            transform: translateY(-1px);
            box-shadow: var(--shadow-lg);
        }

        .auth-footer {
            margin-top: var(--space-6);
            text-align: center;
            font-size: 0.875rem;
            color: var(--text-secondary);
        }

        .auth-footer a {
            color: var(--primary);
            text-decoration: none;
            font-weight: 500;
        }

        .auth-footer a:hover {
            text-decoration: underline;
        }

        /* Right Side - Feature Showcase */
        .auth-sidebar {
            background: linear-gradient(135deg, var(--primary) 0%, #4f46e5 100%);
            padding: var(--space-12);
            display: flex;
            flex-direction: column;
            justify-content: center;
            color: white;
        }

        .sidebar-logo {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: var(--space-8);
            display: flex;
            align-items: center;
            gap: var(--space-2);
        }

        .ai-badge {
            font-size: 0.75rem;
            padding: 0.25rem 0.5rem;
            background: rgba(255, 255, 255, 0.2);
            border-radius: var(--radius-md);
        }

        .sidebar-content h2 {
            font-size: 1.75rem;
            font-weight: 700;
            margin-bottom: var(--space-6);
            line-height: 1.2;
        }

        .features {
            display: flex;
            flex-direction: column;
            gap: var(--space-4);
        }

        .feature {
            display: flex;
            align-items: flex-start;
            gap: var(--space-3);
        }

        .feature-icon {
            width: 24px;
            height: 24px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .feature-content h3 {
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: var(--space-1);
        }

        .feature-content p {
            font-size: 0.875rem;
            opacity: 0.9;
        }

        /* Responsive - ESCAPADO con @@ */
        @@media (max-width: 992px) {
            .auth-container {
                grid-template-columns: 1fr;
            }

            .auth-sidebar {
                display: none;
            }
        }

        @@media (max-width: 576px) {
            .auth-card {
                padding: var(--space-6);
            }

            .auth-header h1 {
                font-size: 1.75rem;
            }
        }
    </style>
</head>
<body>
    <div class="auth-container">
        <!-- Left Side - Login Form -->
        <div class="auth-main">
            <div class="auth-header">
                <h1>Bienvenido de vuelta</h1>
                <p>Inicia sesión para continuar con Spendly</p>
            </div>

            <!-- Google Login -->
            <a href="https://localhost:7267/api/auth/google/login" class="google-btn">
                <svg class="google-icon" viewBox="0 0 24 24">
                    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                    <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                </svg>
                Continuar con Google
            </a>

            <div class="divider">o continúa con email</div>

            <!-- Traditional Login Form -->
            <form asp-action="Login" method="post" class="auth-form">
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="Email" required placeholder="tu@email.com" />
                </div>

                <div class="form-group">
                    <label for="password">Contraseña</label>
                    <input type="password" id="password" name="Password" required placeholder="••••••••" />
                </div>

                <div class="form-actions">
                    <label class="remember-me">
                        <input type="checkbox" name="rememberMe" />
                        <span>Recuérdame</span>
                    </label>
                    <a href="#" class="forgot-password">¿Olvidaste tu contraseña?</a>
                </div>

                <button type="submit" class="submit-btn">Iniciar Sesión</button>
            </form>

            <div class="auth-footer">
                ¿No tienes cuenta? <a href="/auth/register">Regístrate gratis</a>
            </div>
        </div>

        <!-- Right Side - Feature Showcase -->
        <div class="auth-sidebar">
            <div class="sidebar-logo">
                <span>Spendly</span>
                <span class="ai-badge">AI</span>
            </div>

            <div class="sidebar-content">
                <h2>Controla tus gastos con inteligencia artificial</h2>

                <div class="features">
                    <div class="feature">
                        <div class="feature-icon">🤖</div>
                        <div class="feature-content">
                            <h3>Insights AI</h3>
                            <p>Obtén recomendaciones personalizadas basadas en tus hábitos de gasto</p>
                        </div>
                    </div>

                    <div class="feature">
                        <div class="feature-icon">📊</div>
                        <div class="feature-content">
                            <h3>Análisis en Tiempo Real</h3>
                            <p>Visualiza tus gastos y presupuestos con gráficos interactivos</p>
                        </div>
                    </div>

                    <div class="feature">
                        <div class="feature-icon">🎯</div>
                        <div class="feature-content">
                            <h3>Metas Inteligentes</h3>
                            <p>Establece objetivos y recibe alertas cuando te desvíes</p>
                        </div>
                    </div>

                    <div class="feature">
                        <div class="feature-icon">🔒</div>
                        <div class="feature-content">
                            <h3>100% Seguro</h3>
                            <p>Tus datos están protegidos con encriptación de nivel bancario</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
