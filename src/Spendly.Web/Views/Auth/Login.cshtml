@model Spendly.Web.Contracts.Auth.LoginViewModel

@{
    ViewData["Title"] = L["Auth_Login"].Value;
}

<style>
    .auth-bg {
        background-color: var(--clr-bg);
        min-height: calc(100vh - 150px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        margin-top: -48px; /* Offset bootstrap mt-5 in layout */
    }
    .auth-card {
        border: 1px solid var(--clr-border);
        border-radius: 24px;
        box-shadow: var(--shadow-xl);
        background: var(--clr-bg-card);
        padding: 40px;
        width: 100%;
        max-width: 450px;
        transition: transform 0.3s ease;
    }
    .auth-icon {
        width: 64px;
        height: 64px;
        background: rgba(var(--clr-primary-rgb), 0.1);
        color: var(--clr-primary);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        margin: 0 auto 24px;
        border: 1px solid rgba(var(--clr-primary-rgb), 0.2);
        box-shadow: var(--glow-secondary);
    }
    .form-control-custom {
        border-radius: 12px;
        padding: 14px 20px;
        border: 1px solid var(--clr-border);
        background-color: var(--clr-surface-3);
        color: var(--clr-text);
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }
    .form-control-custom:focus {
        background-color: var(--clr-surface);
        border-color: var(--clr-secondary);
        box-shadow: 0 0 0 4px rgba(var(--clr-primary-rgb), 0.15);
        outline: none;
        color: var(--clr-text);
    }
    .btn-auth {
        background: linear-gradient(135deg, var(--clr-primary-light) 0%, var(--clr-primary) 100%);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 14px;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
        margin-top: 10px;
        box-shadow: 0 4px 14px rgba(var(--clr-primary-rgb), 0.2);
    }
    .btn-auth:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(var(--clr-primary-rgb), 0.4);
        color: white;
    }
    .btn-auth:disabled {
        opacity: 0.7;
        transform: none;
        box-shadow: none;
    }
</style>

<div class="auth-bg">
    <div class="auth-card">
        <div class="text-center mb-4">
            <div class="auth-icon">
                <i class="bi bi-wallet2"></i>
            </div>
            <h3 class="fw-bold mb-2" style="font-family:'Calistoga',serif; color: var(--clr-text); letter-spacing:-0.5px;">
                @L["Auth_WelcomeBack"]
            </h3>
            <p class="text-muted small">@L["Auth_WelcomeBack"]</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger border-0 bg-danger bg-opacity-10 text-danger" style="border-radius: 12px; font-size: 0.9rem;">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
            </div>
        }

        <form asp-action="Login" method="post">
            <div class="mb-4">
                <label class="form-label text-muted fw-bold" style="font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.8px;">@L["Auth_Email"]</label>
                <input type="email" name="Email" class="form-control form-control-custom" placeholder="@L["Ph_Email"]" required />
            </div>
            <div class="mb-4">
                <label class="form-label text-muted fw-bold" style="font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.8px;">@L["Auth_Password"]</label>
                <input type="password" name="Password" class="form-control form-control-custom" placeholder="@L["Ph_PasswordHidden"]" required />
                <div class="text-end mt-1">
                    <a asp-action="ForgotPassword" class="text-primary text-decoration-none" style="font-size: 0.82rem;">Forgot password?</a>
                </div>
            </div>
            <button type="submit" class="btn btn-auth w-100">
                @L["Auth_SignIn"]
            </button>
        </form>


        <div class="text-center mt-4 pt-4 border-top" style="border-color: var(--clr-border) !important;">
            <p class="text-muted mb-0" style="font-size: 0.95rem;">
                @L["Auth_NoAccount"] <a asp-action="Register" class="text-primary fw-semibold text-decoration-none">@L["Auth_SignUp"]</a>
            </p>
        </div>
    </div>
</div>

<!-- Loading Overlay -->
<div id="authLoadingOverlay" style="display:none; position:fixed; inset:0; background:rgba(var(--clr-primary-rgb),0.05); backdrop-filter:blur(8px); z-index:9999; 
     display:none; flex-direction:column; align-items:center; justify-content:center;">
    <div class="p-5 rounded-4 text-center border shadow-lg" style="background: var(--clr-bg-card); border-color: var(--clr-border) !important; max-width: 320px;">
        <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Loading...</span>
        </div>
        <h5 class="fw-bold mb-2" style="font-family:'Calistoga',serif; color: var(--clr-text);">@L["Auth_Connecting"]</h5>
        <p class="text-muted small mb-0">@L["Auth_FirstVisit"]</p>
    </div>
</div>

@{
    var apiUrl = ViewBag.ApiBaseUrl as string ?? "";
}

<script>
    // Pre-warm: wake up the API + Database while the user types their credentials
    (function () {
        var api = "@Html.Raw(apiUrl)";
        if (api) {
            fetch(api + "api/health", { mode: "no-cors" }).catch(function () { });
        }
    })();

    // Show loading overlay on form submit
    document.querySelector('form[action*="Login"]').addEventListener('submit', function (e) {
        var overlay = document.getElementById('authLoadingOverlay');
        overlay.style.display = 'flex';

        // Disable button to prevent double-submit
        var btn = this.querySelector('button[type="submit"]');
        if (btn) btn.disabled = true;
    });
</script>