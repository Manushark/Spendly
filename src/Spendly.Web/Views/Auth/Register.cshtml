@model Spendly.Web.Contracts.Auth.RegisterViewModel

@{
    ViewData["Title"] = L["Auth_Register"].Value;
}

<style>
    .auth-bg {
        background-color: #f8f9fc;
        min-height: calc(100vh - 150px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        margin-top: -48px;
    }
    .auth-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
        background: #fff;
        padding: 40px;
        width: 100%;
        max-width: 450px;
    }
    .auth-icon {
        width: 60px;
        height: 60px;
        background: rgba(108, 92, 231, 0.1);
        color: #6c5ce7;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        margin: 0 auto 24px;
        box-shadow: inset 0 0 0 1px rgba(108, 92, 231, 0.2);
    }
    .form-control-custom {
        border-radius: 12px;
        padding: 14px 20px;
        border: 1px solid #e1e5ee;
        background-color: #f8f9fc;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }
    .form-control-custom:focus {
        background-color: #fff;
        border-color: #a29bfe;
        box-shadow: 0 0 0 4px rgba(108, 92, 231, 0.1);
        outline: none;
    }
    .btn-auth {
        background: linear-gradient(135deg, #6c5ce7 0%, #4834d4 100%);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 14px;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
        margin-top: 10px;
    }
    .btn-auth:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(108, 92, 231, 0.25);
        color: white;
    }
</style>

<div class="auth-bg">
    <div class="auth-card">
        <div class="text-center mb-4">
            <div class="auth-icon">
                <i class="bi bi-person-plus"></i>
            </div>
            <h3 class="fw-bold text-dark">@L["Auth_JoinSpendly"]</h3>
            <p class="text-muted">@L["Auth_JoinSpendly"]</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger" style="border-radius: 10px; font-size: 0.9rem;">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
            </div>
        }

        <form asp-action="Register" method="post">
            <div class="mb-4">
                <label class="form-label text-muted fw-semibold" style="font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.5px;">@L["Auth_Email"]</label>
                <input type="email" name="Email" class="form-control form-control-custom" placeholder="name@company.com" required />
            </div>
            <div class="mb-4">
                <label class="form-label text-muted fw-semibold" style="font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.5px;">@L["Auth_Password"]</label>
                <input type="password" name="Password" class="form-control form-control-custom" placeholder="Min. 6 characters" required minlength="6" />
            </div>
            <div class="mb-4">
                <label class="form-label text-muted fw-semibold" style="font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.5px;">@L["Auth_ConfirmPassword"]</label>
                <input type="password" name="ConfirmPassword" class="form-control form-control-custom" placeholder="Repeat password" required />
            </div>
            <button type="submit" class="btn btn-auth w-100">
                @L["Auth_SignUp"]
            </button>
        </form>

        <div class="text-center mt-4 pt-4 border-top">
            <p class="text-muted mb-0" style="font-size: 0.95rem;">
                @L["Auth_HaveAccount"] <a asp-action="Login" class="text-primary fw-semibold text-decoration-none">@L["Auth_SignIn"]</a>
            </p>
        </div>
    </div>
</div>

<!-- Loading Overlay -->
<div id="authLoadingOverlay" style="display:none; position:fixed; inset:0; background:rgba(255,255,255,0.92); z-index:9999; 
     display:none; flex-direction:column; align-items:center; justify-content:center;">
    <div style="text-align:center;">
        <div style="width:48px;height:48px;border:4px solid #e1e5ee;border-top-color:#6c5ce7;border-radius:50%;
                    animation:spin 0.8s linear infinite;margin:0 auto 20px;"></div>
        <h5 style="color:#333;font-weight:600;margin-bottom:8px;">Creating your account...</h5>
        <p style="color:#888;font-size:0.85rem;">This may take a moment on first visit</p>
    </div>
</div>

<style>
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

@{
    var apiUrl = ViewBag.ApiBaseUrl as string ?? "";
}

<script>
    (function () {
        var api = "@Html.Raw(apiUrl)";
        if (api) {
            fetch(api + "api/health", { mode: "no-cors" }).catch(function () { });
        }
    })();

    // Show loading overlay on form submit
    document.querySelector('form[action*="Register"]').addEventListener('submit', function (e) {
        var overlay = document.getElementById('authLoadingOverlay');
        overlay.style.display = 'flex';
        var btn = this.querySelector('button[type="submit"]');
        if (btn) btn.disabled = true;
    });
</script>