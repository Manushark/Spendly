@{
    ViewData["Title"] = "Forgot Password";
}

<style>
    .auth-bg {
        background-color: var(--clr-bg);
        min-height: calc(100vh - 150px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        margin-top: -48px;
    }
    .auth-card {
        border: 1px solid var(--clr-border);
        border-radius: 24px;
        box-shadow: var(--shadow-xl);
        background: var(--clr-bg-card);
        padding: 40px;
        width: 100%;
        max-width: 450px;
    }
    .auth-icon {
        width: 64px;
        height: 64px;
        background: rgba(var(--clr-primary-rgb), 0.1);
        color: var(--clr-primary);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        margin: 0 auto 24px;
        border: 1px solid rgba(var(--clr-primary-rgb), 0.2);
    }
</style>

<div class="auth-bg">
    <div class="auth-card">
        <div class="auth-icon">
            <i class="bi bi-envelope-lock"></i>
        </div>

        <h2 class="text-center fw-bold mb-1" style="color: var(--clr-text)">Forgot Password</h2>
        <p class="text-center mb-4" style="color: var(--clr-text-muted); font-size: 0.9rem">
            Enter your email and we'll send you a reset link.
        </p>

        @if (ViewBag.Success != null)
        {
            <div class="alert alert-success rounded-3 d-flex align-items-center gap-2">
                <i class="bi bi-check-circle-fill"></i>
                <span>@ViewBag.Success</span>
            </div>
        }

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger rounded-3 d-flex align-items-center gap-2">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span>@ViewBag.Error</span>
            </div>
        }

        @if (ViewBag.Success == null)
        {
            <form method="post" action="/Auth/ForgotPassword">
                <div class="mb-3">
                    <label class="form-label fw-semibold" style="color: var(--clr-text)">Email address</label>
                    <div class="input-group">
                        <span class="input-group-text" style="background: var(--clr-bg-input); border-color: var(--clr-border)">
                            <i class="bi bi-envelope" style="color: var(--clr-text-muted)"></i>
                        </span>
                        <input type="email"
                               name="email"
                               class="form-control"
                               placeholder="your@email.com"
                               required
                               style="background: var(--clr-bg-input); border-color: var(--clr-border); color: var(--clr-text)" />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                    <i class="bi bi-send me-2"></i>Send Reset Link
                </button>
            </form>
        }

        <div class="text-center mt-4">
            <a asp-controller="Auth" asp-action="Login" style="color: var(--clr-primary); font-size: 0.9rem">
                <i class="bi bi-arrow-left me-1"></i>Back to Login
            </a>
        </div>
    </div>
</div>
