@model List<Spendly.Web.Services.NotificationDto>

@{
    ViewData["Title"] = L["Notif_Page_Title"].Value;
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var activeFilter = (string)(ViewBag.ActiveFilter ?? "all");
}

<style>
    /* Custom Premium Notification styling */
    .notif-card-premium {
        border-radius: 16px;
        border: 1px solid var(--clr-border);
        background: var(--clr-bg-card);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }
    .notif-row {
        border-bottom: 1px solid var(--clr-border) !important;
        transition: background 0.25s var(--ease-out);
    }
    .notif-row:hover {
        background: rgba(var(--clr-primary-rgb), 0.02) !important;
    }
    .notif-row.is-unread {
        background: rgba(var(--clr-primary-rgb), 0.05) !important;
    }
    
    .nav-pills-notif {
        background: var(--clr-surface-3);
        padding: 6px;
        border-radius: 30px;
        border: 1px solid var(--clr-border);
        display: inline-flex;
    }
    .nav-pills-notif .nav-link {
        color: var(--clr-text-muted);
        background: transparent;
        border: none;
        border-radius: 24px;
        padding: 8px 20px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.25s var(--ease-out);
    }
    .nav-pills-notif .nav-link.active {
        color: #fff !important;
        background: var(--clr-primary) !important;
        box-shadow: 0 4px 12px rgba(var(--clr-primary-rgb), 0.25);
    }
    .nav-pills-notif .nav-link:hover:not(.active) {
        color: var(--clr-text);
        background: rgba(255, 255, 255, 0.05);
    }

    .btn-delete-notif {
        opacity: 0.3;
        transition: all 0.2s var(--ease-out);
        border: none !important;
        background: transparent !important;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        outline: none !important;
        color: var(--clr-text-muted) !important;
    }
    .notif-row:hover .btn-delete-notif {
        opacity: 0.7;
    }
    .btn-delete-notif:hover {
        opacity: 1 !important;
        color: var(--clr-danger) !important;
        background: rgba(var(--clr-danger-rgb), 0.1) !important;
    }
</style>

<div class="container-fluid py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="mb-1" style="font-family:'Calistoga',serif; letter-spacing:-0.5px;">
                <i class="bi bi-bell-fill text-primary me-2"></i>@L["Notif_Page_Title"]
            </h2>
            <small class="text-muted">@L["Notif_Page_Subtitle"]</small>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-primary btn-sm rounded-pill px-4 fw-semibold"
                    id="markAllPageBtn" onclick="markAllReadPage()"
                    @(Model.Any(n => !n.IsRead) ? "" : "disabled")>
                <i class="bi bi-check2-all me-1"></i> @L["Nav_MarkAllRead"]
            </button>
            <button type="button" class="btn btn-outline-danger btn-sm rounded-pill px-4 fw-semibold"
                    id="clearAllPageBtn" onclick="clearAllNotifications()"
                    @(Model.Any() ? "" : "disabled")>
                <i class="bi bi-trash3 me-1"></i> @L["Notif_ClearAll"]
            </button>
        </div>
    </div>

    <!-- Filters -->
    <div class="mb-4">
        <ul class="nav nav-pills nav-pills-notif">
            <li class="nav-item" role="presentation">
                <a class="nav-link @(activeFilter == "all" ? "active" : "")"
                   asp-action="Index" asp-route-filter="all" asp-route-page="1">
                    <i class="bi bi-grid me-1.5"></i> @L["Notif_FilterAll"]
                </a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link @(activeFilter == "unread" ? "active" : "")"
                   asp-action="Index" asp-route-filter="unread" asp-route-page="1">
                    <i class="bi bi-circle-fill me-1.5" style="font-size:0.5rem; vertical-align:middle;"></i> @L["Notif_FilterUnread"]
                </a>
            </li>
        </ul>
    </div>

    @if (Model.Any())
    {
        <div class="card notif-card-premium border-0">
            @foreach (var n in Model)
            {
                var iconClass = n.Type switch
                {
                    "BudgetExceeded"            => "bi-exclamation-triangle-fill text-danger",
                    "BudgetWarning"             => "bi-exclamation-circle-fill text-warning",
                    "RecurringExpenseGenerated" => "bi-arrow-repeat text-info",
                    "SavingsGoalCompleted"      => "bi-trophy-fill text-success",
                    "SavingsGoalMilestone"      => "bi-flag-fill text-primary",
                    _                           => "bi-bell-fill text-secondary"
                };

                var bgIconColor = n.Type switch
                {
                    "BudgetExceeded"            => "rgba(var(--clr-danger-rgb), 0.1)",
                    "BudgetWarning"             => "rgba(var(--clr-warning-rgb), 0.1)",
                    "RecurringExpenseGenerated" => "rgba(var(--clr-info-rgb), 0.1)",
                    "SavingsGoalCompleted"      => "rgba(var(--clr-success-rgb), 0.1)",
                    "SavingsGoalMilestone"      => "rgba(var(--clr-primary-rgb), 0.1)",
                    _                           => "rgba(148, 163, 184, 0.1)"
                };

                var rowClass = n.IsRead ? "" : "is-unread";

                <div class="d-flex align-items-start gap-3 px-4 py-3 notif-row @rowClass"
                     id="notif-@n.Id"
                     style="cursor: @(n.IsRead ? "default" : "pointer")"
                     @(!n.IsRead ? $"onclick=\"markReadPage({n.Id}, this)\"" : "")>

                    <div class="d-flex align-items-center justify-content-center flex-shrink-0 rounded-circle"
                         style="width:42px; height:42px; background: @bgIconColor;">
                        <i class="bi @iconClass fs-5"></i>
                    </div>

                    <div class="flex-grow-1" style="min-width:0;">
                        <p class="mb-1 fw-@(n.IsRead ? "normal" : "semibold")" style="line-height:1.4; color: var(--clr-text);">
                            @n.Message
                        </p>
                        <small class="text-muted font-mono" style="font-size: 0.78rem;">
                            <i class="bi bi-clock me-1"></i>
                            @n.CreatedAt.ToString("MMM dd, yyyy · HH:mm")
                        </small>
                    </div>

                    <div class="flex-shrink-0 d-flex align-items-center gap-3">
                        <div class="notif-status-badge d-flex align-items-center gap-2">
                            @if (!n.IsRead)
                            {
                                <span class="badge bg-primary rounded-pill fw-semibold" style="font-size:0.65rem; padding: 4px 8px;">
                                    @L["Notif_Unread"]
                                </span>
                                <span class="rounded-circle bg-primary d-inline-block" style="width:8px;height:8px;"></span>
                            }
                            else
                            {
                                <span class="text-muted" style="font-size:0.75rem;">
                                    <i class="bi bi-check2-all text-success"></i>
                                </span>
                            }
                        </div>
                        <button type="button" class="btn-delete-notif btn rounded-circle"
                                title="@L["Notif_Delete"]"
                                onclick="deleteNotification(@n.Id, event, this)">
                            <i class="bi bi-trash fs-6"></i>
                        </button>
                    </div>
                </div>
            }
        </div>

        @if (currentPage > 1 || Model.Count == 20)
        {
            <div class="d-flex justify-content-center gap-2 mt-4">
                @if (currentPage > 1)
                {
                    <a asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-filter="@activeFilter"
                       class="btn btn-outline-secondary btn-sm rounded-pill px-4">
                        <i class="bi bi-chevron-left me-1"></i> @L["Common_Previous"]
                    </a>
                }
                <span class="btn btn-light btn-sm rounded-pill px-4 disabled">
                    @currentPage
                </span>
                @if (Model.Count == 20)
                {
                    <a asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-filter="@activeFilter"
                       class="btn btn-outline-secondary btn-sm rounded-pill px-4">
                        @L["Common_Next"] <i class="bi bi-chevron-right ms-1"></i>
                    </a>
                }
            </div>
        }
    }
    else
    {
        <div class="card notif-card-premium border-0 p-5 text-center">
            <div class="text-primary opacity-25 mb-3" style="font-size: 4rem;">
                <i class="bi bi-bell-slash"></i>
            </div>
            <h5 class="fw-bold mb-1" style="font-family:'Calistoga',serif;">@L["Notif_NoHistory"]</h5>
            <p class="text-muted mb-0">
                @(activeFilter == "unread" ? L["Notif_NoUnread"].Value : L["Notif_NoHistory"].Value)
            </p>
        </div>
    }
</div>

@section Scripts {
    <script>
        function markReadPage(id, el) {
            fetch(`/Notifications/MarkAsRead/${id}`, { method: 'POST' })
                .then(r => r.json())
                .then(() => {
                    if (!el) return;
                    el.classList.remove('is-unread');
                    el.style.cursor = 'default';
                    el.removeAttribute('onclick');

                    const badge = el.querySelector('.badge.bg-primary');
                    const dot   = el.querySelector('.rounded-circle.bg-primary.d-inline-block');
                    if (badge) badge.remove();

                    const badgeContainer = el.querySelector('.notif-status-badge');
                    if (badgeContainer) {
                        badgeContainer.innerHTML = '<span class="text-muted" style="font-size:0.75rem;"><i class="bi bi-check2-all text-success"></i></span>';
                    }

                    const msg = el.querySelector('p.fw-semibold');
                    if (msg) { msg.classList.remove('fw-semibold'); msg.classList.add('fw-normal'); }

                    if (typeof loadNotificationCount === 'function') loadNotificationCount();
                });
        }

        function markAllReadPage() {
            fetch('/Notifications/MarkAllAsRead', { method: 'POST' })
                .then(() => window.location.reload());
        }

        function deleteNotification(id, event, btn) {
            if (event) {
                event.stopPropagation();
                event.preventDefault();
            }

            const row = document.getElementById(`notif-${id}`);
            if (row) {
                row.style.transition = 'all 0.35s cubic-bezier(0.4, 0, 0.2, 1)';
                row.style.opacity = '0';
                row.style.transform = 'translateX(30px)';
                row.style.height = '0';
                row.style.padding = '0';
                row.style.borderBottom = 'none';
                
                setTimeout(() => {
                    row.remove();
                    const container = document.querySelector('.notif-card-premium');
                    if (container && container.querySelectorAll('.notif-row').length === 0) {
                        window.location.reload();
                    }
                }, 350);
            }

            fetch(`/Notifications/Delete/${id}`, { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        if (typeof loadNotificationCount === 'function') {
                            loadNotificationCount();
                        }
                    }
                });
        }

        function clearAllNotifications() {
            const isEs = document.documentElement.lang === 'es';
            const confirmMsg = isEs 
                ? '¿Estás seguro de que deseas borrar todas las notificaciones?' 
                : 'Are you sure you want to clear all notifications?';
            
            if (!confirm(confirmMsg)) {
                return;
            }

            const container = document.querySelector('.notif-card-premium');
            if (container) {
                const rows = container.querySelectorAll('.notif-row');
                rows.forEach((row, index) => {
                    setTimeout(() => {
                        row.style.transition = 'all 0.35s cubic-bezier(0.4, 0, 0.2, 1)';
                        row.style.opacity = '0';
                        row.style.transform = 'translateX(30px)';
                    }, index * 50);
                });
            }

            fetch('/Notifications/DeleteAll', { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        setTimeout(() => {
                            window.location.reload();
                        }, 400);
                    }
                });
        }
    </script>
}
