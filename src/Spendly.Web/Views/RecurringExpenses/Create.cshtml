@model Spendly.Web.Contracts.RecurringExpenses.CreateRecurringExpenseDto

@{
    ViewData["Title"] = "Create Recurring Expense";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-plus-circle me-2"></i>@L["Rec_NewRecurring"]
                    </h4>
                </div>
                <div class="card-body p-4">
                    @if (TempData["Error"] is string errorMsg)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMsg
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label class="form-label fw-semibold">
                                    <i class="bi bi-text-left me-1"></i>@L["Common_Description"]
                                </label>
                                <input asp-for="Description" 
                                       class="form-control form-control-lg" 
                                       placeholder="@L["Ph_RecurringName"]"
                                       required 
                                       maxlength="200" />
                                <small class="text-muted">@L["Rec_DescHint"]</small>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold">
                                    <i class="bi bi-cash-stack me-1"></i>@L["Common_Amount"]
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text">$</span>
                                    <input asp-for="Amount" 
                                           type="number" 
                                           step="0.01" 
                                           min="0.01"
                                           class="form-control" 
                                           placeholder="@L["Ph_Zero"]"
                                           required />
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">
                                    <i class="bi bi-tag me-1"></i>@L["Common_Category"]
                                </label>
                                <input asp-for="Category" 
                                       class="form-control form-control-lg" 
                                       placeholder="@L["Ph_CategoryName"]"
                                       required 
                                       maxlength="100"
                                       list="categoryList" />
                                <datalist id="categoryList">
                                    <option value="Entertainment"/>
                                    <option value="Utilities"/>
                                    <option value="Transportation"/>
                                    <option value="Food"/>
                                    <option value="Health"/>
                                    <option value="Insurance"/>
                                    <option value="Subscriptions"/>
                                    <option value="Other"/>
                                </datalist>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">
                                    <i class="bi bi-arrow-repeat me-1"></i>@L["Common_Frequency"]
                                </label>
                                <select asp-for="Frequency" class="form-select form-select-lg" required>
                                    <option value="1">@L["Freq_Daily"]</option>
                                    <option value="2">@L["Freq_Weekly"]</option>
                                    <option value="3" selected>@L["Freq_Monthly"]</option>
                                    <option value="4">@L["Freq_Yearly"]</option>
                                </select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">
                                    <i class="bi bi-play-circle me-1"></i>@L["Rec_StartDate"]
                                </label>
                                <input asp-for="StartDate" 
                                       type="date"
                                       class="form-control form-control-lg" 
                                       required />
                                <small class="text-muted">@L["Rec_StartDateHint"]</small>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">
                                    <i class="bi bi-stop-circle me-1"></i>@L["Rec_EndDate"]
                                </label>
                                <input asp-for="EndDate" 
                                       type="date"
                                       class="form-control form-control-lg" />
                                <small class="text-muted">@L["Rec_EndDateHint"]</small>
                            </div>
                        </div>

                        <div class="alert alert-info border-0 bg-info bg-opacity-10">
                            <h6 class="fw-semibold mb-2">
                                <i class="bi bi-info-circle me-2"></i>@L["Rec_HowItWorks"]
                            </h6>
                            <ul class="mb-0 small">
                                <li>@L["Rec_How1"]</li>
                                <li>@L["Rec_How2"]</li>
                                <li>@L["Rec_How3"]</li>
                            </ul>
                        </div>

                        <div class="d-flex gap-2 justify-content-end mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-x-circle me-1"></i>@L["Common_Cancel"]
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-circle me-1"></i>@L["Rec_NewRecurring"]
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @* Examples *@
            <div class="card border-0 bg-light mt-3">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3">
                        <i class="bi bi-lightbulb text-warning me-2"></i>@L["Rec_ExamplesTitle"]
                    </h6>
                    <div class="row g-2 small">
                        <div class="col-md-6">
                            @Html.Raw(L["Rec_Ex1"].Value)
                        </div>
                        <div class="col-md-6">
                            @Html.Raw(L["Rec_Ex2"].Value)
                        </div>
                        <div class="col-md-6">
                            @Html.Raw(L["Rec_Ex3"].Value)
                        </div>
                        <div class="col-md-6">
                            @Html.Raw(L["Rec_Ex4"].Value)
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}