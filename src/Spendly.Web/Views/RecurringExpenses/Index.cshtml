@model Spendly.Web.Contracts.RecurringExpenses.RecurringExpenseSummaryDto

@{
    ViewData["Title"] = "Recurring Expenses";
}

<style>
    .recurring-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border-left: 4px solid #dee2e6;
    }
    .recurring-card.active {
        border-left-color: #198754;
    }
    .recurring-card.paused {
        border-left-color: #ffc107;
        opacity: 0.7;
    }
    .recurring-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.12) !important;
    }
    .frequency-badge {
        font-size: 0.75rem;
        padding: 4px 8px;
    }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">
                <i class="bi bi-arrow-repeat text-primary"></i> Recurring Expenses
            </h2>
            <small class="text-muted">
                Automatic expense templates
            </small>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Recurring Expense
        </a>
    </div>

    @* Alerts *@
    @if (TempData["Error"] is string errorMsg)
    {
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMsg
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
    }
    @if (TempData["Success"] is string successMsg)
    {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="bi bi-check-circle-fill me-2"></i>@successMsg
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
    }

    @if (!Model.Recurrences.Any())
    {
            <div class="card shadow-sm border-0">
                <div class="card-body text-center py-5">
                    <div class="mb-4" style="font-size: 80px; opacity: 0.3;">
                        <i class="bi bi-arrow-repeat"></i>
                    </div>
                    <h3 class="mb-3">No recurring expenses yet</h3>
                    <p class="text-muted mb-4">
                        Automate your regular expenses like subscriptions, bills, and memberships
                    </p>
                    <a asp-action="Create" class="btn btn-primary btn-lg">
                        <i class="bi bi-plus-circle me-2"></i>Create Your First Recurring Expense
                    </a>
                </div>
            </div>
    }
    else
    {
        @* Summary Cards *@
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card shadow-sm border-0">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <p class="text-muted mb-1 small text-uppercase fw-semibold">Total Recurrences</p>
                                    <h4 class="mb-0 fw-bold">@Model.TotalRecurrences</h4>
                                </div>
                                <div class="bg-primary bg-opacity-10 p-3 rounded">
                                    <i class="bi bi-arrow-repeat text-primary fs-4"></i>
                                </div>
                            </div>
                            <small class="text-muted">@Model.ActiveRecurrences active</small>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card shadow-sm border-0">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <p class="text-muted mb-1 small text-uppercase fw-semibold">Monthly Projected</p>
                                    <h4 class="mb-0 fw-bold">$@Model.MonthlyProjectedTotal.ToString("N2")</h4>
                                </div>
                                <div class="bg-success bg-opacity-10 p-3 rounded">
                                    <i class="bi bi-calendar-month text-success fs-4"></i>
                                </div>
                            </div>
                            <small class="text-muted">Estimated per month</small>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card shadow-sm border-0">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <p class="text-muted mb-1 small text-uppercase fw-semibold">Paused</p>
                                    <h4 class="mb-0 fw-bold">@(Model.TotalRecurrences - Model.ActiveRecurrences)</h4>
                                </div>
                                <div class="bg-warning bg-opacity-10 p-3 rounded">
                                    <i class="bi bi-pause-circle text-warning fs-4"></i>
                                </div>
                            </div>
                            <small class="text-muted">Temporarily inactive</small>
                        </div>
                    </div>
                </div>
            </div>

        @* Recurring Expenses List *@
            <div class="row g-3">
            @foreach (var recurring in Model.Recurrences)
            {
                var frequencyIcon = recurring.Frequency switch
                {
                    "Daily" => "calendar-day",
                    "Weekly" => "calendar-week",
                    "Monthly" => "calendar-month",
                    "Yearly" => "calendar-event",
                    _ => "calendar"
                };

                var statusClass = recurring.IsActive ? "active" : "paused";

                        <div class="col-md-6">
                            <div class="card recurring-card @statusClass shadow-sm">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div class="flex-grow-1">
                                            <h5 class="mb-1 fw-semibold">@recurring.Description</h5>
                                            <div class="d-flex gap-2 align-items-center flex-wrap mt-2">
                                                <span class="badge bg-secondary">@recurring.Category</span>
                                                <span class="badge bg-info frequency-badge">
                                                    <i class="bi bi-@frequencyIcon me-1"></i>@recurring.Frequency
                                                </span>
                                        @if (recurring.IsActive)
                                        {
                                                        <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                                        <span class="badge bg-warning text-dark">Paused</span>
                                        }
                                            </div>
                                        </div>
                                        <h4 class="mb-0 text-primary">$@recurring.Amount.ToString("N2")</h4>
                                    </div>

                                    <div class="mb-3">
                                        <div class="row g-2 small">
                                            <div class="col-6">
                                                <i class="bi bi-play-circle text-muted me-1"></i>
                                                <strong>Starts:</strong> @recurring.StartDate.ToString("MMM dd, yyyy")
                                            </div>
                                    @if (recurring.EndDate.HasValue)
                                    {
                                                    <div class="col-6">
                                                        <i class="bi bi-stop-circle text-muted me-1"></i>
                                                        <strong>Ends:</strong> @recurring.EndDate.Value.ToString("MMM dd, yyyy")
                                                    </div>
                                    }
                                    else
                                    {
                                                    <div class="col-6 text-muted">
                                                        <i class="bi bi-infinity me-1"></i>
                                                        <strong>Indefinite</strong>
                                                    </div>
                                    }
                                        </div>
                                @if (recurring.LastGeneratedDate.HasValue)
                                {
                                                <div class="small text-muted mt-2">
                                                    <i class="bi bi-check-circle me-1"></i>
                                                    Last generated: @recurring.LastGeneratedDate.Value.ToString("MMM dd, yyyy")
                                                </div>
                                }
                                @if (recurring.NextOccurrence.HasValue && recurring.IsActive)
                                {
                                                <div class="small text-success mt-1">
                                                    <i class="bi bi-arrow-right-circle me-1"></i>
                                                    Next: @recurring.NextOccurrence.Value.ToString("MMM dd, yyyy")
                                                </div>
                                }
                                    </div>

                                    <div class="d-flex gap-2 justify-content-end">
                                        <a asp-action="Edit" asp-route-id="@recurring.Id" 
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>

                                        <form asp-action="Toggle" asp-route-id="@recurring.Id" 
                                              asp-route-activate="@(!recurring.IsActive)"
                                              method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    @if (recurring.IsActive)
                                    {
                                                    <button type="submit" class="btn btn-sm btn-outline-warning">
                                                        <i class="bi bi-pause"></i> Pause
                                                    </button>
                                    }
                                    else
                                    {
                                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                                        <i class="bi bi-play"></i> Activate
                                                    </button>
                                    }
                                        </form>

                                        <form asp-action="Delete" asp-route-id="@recurring.Id" 
                                              method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Delete this recurring expense?');">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
            }
            </div>
    }
</div>
