# ─────────────────────────────────────────────────────────
# Spendly API — Production Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your production values.
# These variables override appsettings.json at runtime.
#
# ASP.NET Core reads environment variables using the
# double-underscore (__) convention for nested keys:
#   "Jwt:Key" in JSON  →  Jwt__Key as env var
# ─────────────────────────────────────────────────────────

# Required: Database connection string (no TrustServerCertificate in production)
ConnectionStrings__DefaultConnection=Server=your-prod-server.database.windows.net;Database=SpendlyDb;User Id=spendly_app;Password=YOUR_STRONG_PASSWORD;Encrypt=True;

# Required: JWT signing key (minimum 32 characters, random and unique per environment)
Jwt__Key=REPLACE_WITH_A_STRONG_RANDOM_KEY_AT_LEAST_32_CHARS

# Optional: JWT Issuer (default: Spendly)
Jwt__Issuer=Spendly

# Optional: JWT Audience (default: SpendlyUsers)
Jwt__Audience=SpendlyUsers

# Optional: Token expiration in minutes (default: 120)
Jwt__ExpirationMinutes=120

# Required: Set to Production for production deployments
ASPNETCORE_ENVIRONMENT=Production
